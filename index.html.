    allPositions.push({pos:p,name:ai.name,emoji:ai.emoji,isMe:false,gap:-(RS.playerPos-p),gapStr:p===1?'LEADER':`+${((RS.playerPos-p)*2.1).toFixed(2)}s`,isAhead:p===RS.playerPos-1});
  }
  allPositions.push({pos:RS.playerPos,name:'YOU',emoji:G.team.d1?.emoji||G.team.d2?.emoji||'🏎',isMe:true,gap:0,gapStr:RS.playerPos===1?'LEADER':'+'+(RS.aheadGap.toFixed(2))+'s'});
  // AI after player
  for(let p=RS.playerPos+1;p<=Math.min(RS.playerPos+3,14);p++){
    const ai=RS.grid.find(d=>d.pos===p)||{name:AI_NAMES[p-1]||'AI '+p,emoji:'🚗',isMe:false};
    const gap=(p-RS.playerPos)*1.5+Math.random();
    allPositions.push({pos:p,name:ai.name,emoji:ai.emoji,isMe:false,gap:gap,gapStr:'+'+gap.toFixed(2)+'s'});
  }
  panel.innerHTML=allPositions.map(e=>{
