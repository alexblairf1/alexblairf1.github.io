function setFilter(f){COL_FILTER=f;renderCollection();}

// ════ CARD BUILDERS ════
function cardHtml(d,isLg){
  const tc=TIER[d.tier]?.color||'#888';const isCar=!!d.speed;const lvl=G.upgrades[d.id]||0;
  const statsHtml=isCar?`<div class="dc-stats three"><div><div class="dc-sv">${d.speed+(lvl*2)}</div><div class="dc-sl">SPD</div></div><div><div class="dc-sv">${d.handling+(lvl*2)}</div><div class="dc-sl">HND</div></div><div><div class="dc-sv">${d.overall+(lvl*3)}</div><div class="dc-sl">OVR</div></div></div>`:
    `<div class="dc-stats"><div><div class="dc-sv">${d.overall+(lvl*2)}</div><div class="dc-sl">OVR</div></div><div><div class="dc-sv">${d.pace+lvl}</div><div class="dc-sl">PAC</div></div><div><div class="dc-sv">${d.consistency+lvl}</div><div class="dc-sl">CON</div></div><div><div class="dc-sv">${d.overtaking+lvl}</div><div class="dc-sl">OVT</div></div></div>`;
  return `<div class="dc-stripe" style="background:${d.tc||'#333'}"></div><div class="dc-inner"><div class="dc-badge"><span class="tb ${TIER[d.tier]?.badge||'tb-br'}">${TIER[d.tier]?.label||'BRONZE'}</span></div>${d.era?`<div class="dc-era">${d.era}</div>`:''}<div class="dc-emo">${d.emoji}</div><div class="dc-name">${d.short||d.name}</div><div class="dc-team">${d.team}</div>${isLg?`<div class="dc-ovr" style="color:${tc}">${d.overall+(lvl*2)}</div>`:''}<div class="dc-num-bg">${d.num||''}</div>${statsHtml}${d.special?`<div class="dc-sp-label">${d.special}</div>`:''}</div>`;
