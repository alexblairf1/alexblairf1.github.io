const SCREENS=['home','packs','cards','team','season','events','mydriver'];
function goTo(name,btn){
  SCREENS.forEach(s=>{document.getElementById('scr-'+s)?.classList.remove('active');});
  document.getElementById('scr-'+name)?.classList.add('active');
  document.querySelectorAll('.nb').forEach(b=>b.classList.remove('on'));
  if(btn) btn.classList.add('on');
  else{const m={home:0,packs:1,cards:2,team:3,season:4,events:5,mydriver:6};if(m[name]!==undefined)document.querySelectorAll('.nb')[m[name]]?.classList.add('on');}
  if(name==='cards')renderCollection();
  if(name==='team')renderTeam();
  if(name==='season')renderSeason();
  if(name==='home')renderHome();
}

