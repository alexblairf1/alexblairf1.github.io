function rebuildLB(){
  const names=['Hamilton','Verstappen','Leclerc','Norris','Alonso','Vettel','Schumacher','Senna','Raikkonen','Prost','Lauda','Mansell','Piquet','Hill','Stewart','Hakkinen','Button','Villeneuve','Coulthard','Barrichello','Rosberg','Webber','Massa','Ricciardo','Sainz'];
  Object.keys(LEAGUES).forEach(lid=>{
    const lg=LEAGUES[lid];
    if(!G.season[lid].lb){
      const es=names.slice(0,19).map((n,i)=>({name:n,pts:Math.floor(Math.random()*lg.races.length*18)+5,wins:Math.floor(Math.random()*3)}));
      es.sort((a,b)=>b.pts-a.pts);
      G.season[lid].lb=[{name:'YOU',pts:G.season[lid].points,wins:G.season[lid].wins,isMe:true},...es];
    } else {
      const me=G.season[lid].lb.find(e=>e.isMe);
      if(me){me.pts=G.season[lid].points;me.wins=G.season[lid].wins;}
    }
  });
}

