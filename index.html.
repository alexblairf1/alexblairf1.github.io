.moverlay.on{display:flex;}
.msheet{background:var(--bg2);border:1px solid var(--border);border-radius:18px 18px 0 0;width:100%;max-width:500px;padding:16px;max-height:85vh;overflow-y:auto;animation:slideUp .22s cubic-bezier(.34,1.2,.64,1);}
