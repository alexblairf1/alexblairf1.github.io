}
function isLeagueUnlocked(id){const order=['br','si','go','ep'];if(order.indexOf(id)===0)return true;return getTeamOvr()>=LEAGUES[id].minOvr;}
function getTeamOvr(){const d1=G.team.d1,d2=G.team.d2,car=G.team.car;const drivers=[d1,d2].filter(Boolean);if(!drivers.length)return 0;const dOvr=Math.round(drivers.reduce((s,d)=>s+(d.overall+(G.upgrades[d.id]||0)*2),0)/drivers.length);return Math.min(100,dOvr+(car?Math.round(car.overall*.15):0));}

// ════ RACE ENGINE WITH INTERACTIVE OVERTAKING ════
const AI_NAMES=['Hamilton','Verstappen','Leclerc','Norris','Alonso','Vettel','Schumacher','Senna','Raikkonen','Prost','Lauda','Mansell','Piquet','Hill','Stewart'];

function startRace(race,raceIdx,leagueId){
  const d1=G.team.d1,d2=G.team.d2;
  if(!d1&&!d2){toast('⚠️ Add drivers to your team!');goTo('team');return;}
  const teamOvr=getTeamOvr();const lg=LEAGUES[leagueId];
  if(teamOvr<lg.minOvr){toast(`❌ Team OVR ${teamOvr} — need ${lg.minOvr}`);return;}
  const player=d1||d2;const carBonus=G.team.car?Math.round(G.team.car.overall*.1):0;
  const playerOvr=player.overall+(G.upgrades[player.id]||0)*2+carBonus;
  // Build AI grid — opponents slightly above/below player
  const aiPool=lg.aiTiers.flatMap(t=>DRIVERS_RAW.filter(d=>d.tier===t));
  const aiGrid=aiPool.sort(()=>Math.random()-.5).slice(0,13).map((d,i)=>({name:AI_NAMES[i]||d.short,ovr:d.overall+(Math.random()*6-3),emoji:'🚗',isMe:false,pos:i+2}));
  const startPos=Math.max(4,Math.min(12,Math.round(7+(1-(playerOvr/100))*5)+Math.floor(Math.random()*3)-1));
  // Set initial gaps (seconds behind car ahead)
  const gaps={};aiGrid.forEach((d,i)=>{d.pos=i<startPos-1?i+1:i+2;gaps[d.name]=i<startPos-1?(i+1)*1.5:Math.random()*3+1;});
  const aheadCar=aiGrid.find(d=>d.pos===startPos-1);
  // Decisions
  const numDec=lg.decisions;
  const decPool=[...DECISIONS].sort(()=>Math.random()-.5).slice(0,numDec);
  const totalLaps=race.laps;
  const decLaps=decPool.map((_,i)=>Math.floor(totalLaps*(i+1)/(numDec+1)));
  RS={active:true,league:leagueId,raceIdx,grid:aiGrid,playerPos:startPos,playerOvr,carBonus,
    lap:1,totalLaps,running:true,logs:[],raceObj:race,
    decisions:decPool,decLaps,nextDecIdx:0,posAdjust:0,dnf:false,pitUsed:false,pitBonus:0,
    overtakeCooldown:0,defendCooldown:0,otCoolMax:4000,defCoolMax:5000,
    otTimer:null,defTimer:null,
    aheadGap:aheadCar?2.5+Math.random():99,behindGap:2+Math.random()*3,
    overtakesThisRace:0,defenseThisRace:0,raceBaseOvr:playerOvr,
    lapInterval:null,
  };
  document.getElementById('race-ov').classList.add('on');
  addRaceLog('LIGHTS OUT — RACE BEGINS!','hi');
  updateRaceUI();
  updateCarPositions();
}

function addRaceLog(msg,cls=''){
  RS.logs.unshift({msg:`LAP ${RS.lap}: ${msg}`,cls});
  if(RS.logs.length>8)RS.logs.pop();
  const panel=document.getElementById('race-log-panel');
  if(panel)panel.innerHTML=RS.logs.map(l=>`<div class="rle ${l.cls}">${l.msg}</div>`).join('');
}

function updateCarPositions(){
  const carMain=document.getElementById('car-main');
  const carAi1=document.getElementById('car-ai1');
  const carAi2=document.getElementById('car-ai2');
  const carBehind=document.getElementById('car-behind');
  if(!carMain)return;
  // Player car position based on gap to car ahead
  const pctAhead=Math.min(RS.aheadGap/8,1);// 0=right behind, 1=far
  carMain.style.left=(38+pctAhead*15)+'%';
  // Car ahead
  carAi1.style.left=(60+Math.sin(Date.now()*.001)*3)+'%';
  carAi1.style.bottom='52px';
  // Car further ahead
  if(RS.playerPos>2){
    carAi2.style.display='block';
    carAi2.style.left=(72+Math.cos(Date.now()*.0008)*4)+'%';
  } else {
    carAi2.style.display='none';
  }
  // Car behind
  const pctBehind=Math.min(RS.behindGap/6,1);
  carBehind.style.left=(18-pctBehind*10)+'%';
  // Gap badge
  const gapBadge=document.getElementById('race-gap-badge');
  if(gapBadge){
    const g=RS.aheadGap;
    const color=g<0.5?'#ff2244':g<1.5?'#ffaa00':'#b0b0b0';
    gapBadge.style.borderColor=color;gapBadge.style.color=color;
    gapBadge.textContent=RS.playerPos===1?'LEADER':('GAP: '+(g>50?'> 50s':g.toFixed(2)+'s'));
  }
}

const LAP_EVENTS=[
  ()=>({msg:'Pushing hard through the final sector',cls:'',gapChange:-0.15}),
  ()=>({msg:'Catching the car ahead! Gap closing!',cls:'hi',gapChange:-0.4}),
  ()=>({msg:'SAFETY CAR — field bunches up!',cls:'warn',gapChange:-1.2}),
  ()=>({msg:'DRS ENABLED — full attack!',cls:'hi',gapChange:-0.5}),
  ()=>({msg:'YELLOW FLAG in sector 3',cls:'warn',gapChange:+0.3}),
