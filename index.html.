  lbadge.textContent=lg.emoji+' '+lg.label.split(' ')[0];
  lbadge.className='hud-league hl-'+G.league;
  G.level=Math.max(1,Math.floor(1+Math.pow(G.xp/120,.62)));
}
function addXP(amt){
  G.xp+=amt; updateHUD();
  // check league unlocks
  checkLeagueUnlocks();
}
function addCoins(amt){G.coins+=amt;updateHUD();}
function checkLeagueUnlocks(){
  const teamOvr=calcTeamOvr();
  LEAGUES.forEach(lg=>{
    if(!G.unlockedLeagues.includes(lg.id)&&teamOvr>=lg.minOvr){
      G.unlockedLeagues.push(lg.id);
      toast(`🏆 ${lg.label} UNLOCKED!`);
    }
  });
}

/* ──────────────────────────────────────────────
   COLLECTION HELPERS
────────────────────────────────────────────── */
function addCard(card){
  if(!card) return;
  // no duplicates by id
  if(G.col.find(c=>c.id===card.id)) return;
  const c={...card, uid:card.id+'_'+Date.now()};
  G.col.push(c);
  // check objectives
  if(['si'].includes(card.tier)) completeObj('o_silver');
  if(card.tier==='go') completeObj('o_gold');
  if(card.tier==='ep') completeObj('o_epic');
  if(card.isCar&&card.tier==='sp') completeObj('o_sp_car');
}

function calcTeamOvr(){
  const drivers=[G.team.d1,G.team.d2,{...G.myDriver}].filter(Boolean);
  const car=G.team.car;
  const dOvr=drivers.length?Math.round(drivers.reduce((s,d)=>s+d.overall,0)/drivers.length):0;
  const carBonus=car?Math.round(car.overall*.12):0;
  return Math.min(100,dOvr+carBonus);
}

