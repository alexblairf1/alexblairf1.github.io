function makeDecision(optIdx){
  const dec=RS.pendingDecision;
  dec.opts[optIdx].fn(RS);
  RS.pendingDecision=null;
  RS.decisionLaps=RS.decisionLaps.filter(l=>l!==RS.lap);
  renderRace();
}

function advanceLap(){
  if(RS.lap>=RS.totalLaps){RS.done=true;renderRace();return;}
  // random lap event
  const events=[
    ()=>RS.logs.push({t:`LAP ${RS.lap}: ${['Great sector 1!','DRS activated!','Catching P'+(Math.max(1,RS.grid.findIndex(d=>d.isMe)))+' ahead!','Managing gap of '+(Math.random()*2+.1).toFixed(3)+'s'][Math.floor(Math.random()*4)]}`,c:'hi'}),
    ()=>{RS.logs.push({t:`LAP ${RS.lap}: Rivals pitting — stay out or follow?`,c:'warn'});sortGrid(RS,0.55);},
    ()=>RS.logs.push({t:`LAP ${RS.lap}: ${['Fastest lap secured!','Pushed through sector 3!','Gap holding stable.','Pressure from behind!'][Math.floor(Math.random()*4)]}`,c:Math.random()>.5?'ok':'hi'}),
  ];
  events[Math.floor(Math.random()*events.length)]();
  sortGrid(RS,0.55);
  RS.lap++;
  if(RS.lap>RS.totalLaps){RS.done=true;}
  renderRace();
}

function skipToFinish(){
  // Run remaining laps
  for(let i=RS.lap;i<=RS.totalLaps;i++){
    sortGrid(RS,0.58);
  }
  RS.lap=RS.totalLaps;
  RS.done=true;
  RS.logs.push({t:`CHEQUERED FLAG — P${RS.grid.findIndex(d=>d.isMe)+1}!`,c:RS.grid[0].isMe?'ok':'hi'});
  renderRace();
}

function collectRaceReward(coins,pts,xp,pos){
  addCoins(coins); addXP(xp);
  G.leaguePoints[activeLeague]=(G.leaguePoints[activeLeague]||0)+pts;
  if(pos===1){G.leagueWins[activeLeague]=(G.leagueWins[activeLeague]||0)+1;completeObj('o_win');}
  G.leagueProgress[activeLeague]=(G.leagueProgress[activeLeague]||0)+1;
  completeObj('o_race');

  // Update AI leaderboard
  G.lbAI[activeLeague].forEach(ai=>ai.pts+=Math.floor(Math.random()*20));

  closeRace();
  renderSeason();
  renderHome();

  // Pick 1 of 3 card reward sometimes
  if(pos<=3&&Math.random()>.5){
    const lg=RS.league;
    const rewardTier=pos===1?(lg.id==='ep'?'ep':'go'):(lg.id==='br'?'br':'si');
    offerPickReward(rewardTier);
  } else {
    toast(pos===1?`🏆 VICTORY! +🪙${coins.toLocaleString()}`:` P${pos} — +🪙${coins.toLocaleString()}`);
  }
}

function offerPickReward(tier){
  // generate 3 different cards of the tier
  const pool=[...ALL_DRIVERS.filter(d=>d.tier===tier&&!G.col.find(c=>c.id===d.id)),
              ...ALL_CARS.filter(c=>c.tier===tier&&!G.col.find(x=>x.id===c.id))];
  if(pool.length<1){toast('🎁 Reward claimed!');return;}
  const shuffled=pool.sort(()=>Math.random()-.5).slice(0,Math.min(3,pool.length));
  // pad with duplicates if needed
  while(shuffled.length<3) shuffled.push(pool[Math.floor(Math.random()*pool.length)]);

  const overlay=document.getElementById('pick-overlay');
  overlay.classList.add('show');
  const cardsDiv=document.getElementById('pick-cards');
  cardsDiv.innerHTML='<div style="font-size:11px;color:var(--dim);margin-bottom:8px;text-align:center">Pick 1 — others are gone</div>';
  shuffled.forEach(card=>{
    const el=makeSmallCard(card);
    el.style.transform='scale(1.05)';
    el.onclick=()=>{
      addCard(card);
      overlay.classList.remove('show');
      toast(`✅ ${card.name} added to collection!`);
      renderCollection();renderHome();
    };
    cardsDiv.appendChild(el);
  });
}

