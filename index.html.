function startRace(race,lg,raceIdx){
  const players=[G.team.d1,G.team.d2,G.myDriver].filter(Boolean);
  if(!players.length){toast('⚠️ Add drivers to your team first!');goTo('team');return;}
  if(calcTeamOvr()<(lg.minOvr||0)){toast(`❌ Team OVR too low! Need ${lg.minOvr}`);return;}

  const myOvr=calcTeamOvr();
  const carBonus=G.team.car?Math.round(G.team.car.overall*.08):0;

  // Build grid
  const aiCount=13;
  const aiOvrs=lg.aiOvr||[];
  const grid=[{name:'⭐ '+G.team.name,ovr:myOvr+carBonus,isMe:true,gap:0}];
  for(let i=0;i<aiCount;i++){
    const aiOvr=aiOvrs[i]||(70+Math.random()*20);
    grid.push({name:AI_NAMES[i%AI_NAMES.length],ovr:Math.round(aiOvr+(Math.random()-0.5)*4),isMe:false,gap:0});
  }
  // Starting position based on ovr vs field
  grid.sort((a,b)=>(b.ovr+Math.random()*8)-(a.ovr+Math.random()*8));
  // ensure not starting last if ovr is decent
  const myIdx=grid.findIndex(d=>d.isMe);
  if(myIdx>Math.ceil(grid.length*.7)&&myOvr>=70){
    const me=grid.splice(myIdx,1)[0];
    grid.splice(Math.floor(grid.length*.5)+Math.floor(Math.random()*3),0,me);
  }

  RS={active:true,grid,lap:0,totalLaps:race.laps,logs:[],decisions:[],pendingDecision:null,
      league:lg,raceIdx,race,done:false,decisionLaps:[]};

  // set which laps have decisions (random 3-5 decisions)
  const numDecisions=Math.floor(3+Math.random()*3);
  const lapSlots=[];
  for(let i=0;i<numDecisions;i++) lapSlots.push(Math.floor((i+1)*race.laps/(numDecisions+1)));
  RS.decisionLaps=lapSlots;

  RS.logs.push({t:'LIGHTS OUT — RACE BEGINS!',c:'hi'});
  sortGrid(RS,0.5);
  RS.lap=1;

  document.getElementById('race-over').classList.add('show');
  renderRace();
}

function sortGrid(rs,playerAdvantage=0.5,playerBonus=false){
  rs.grid.sort((a,b)=>{
    const as=a.ovr+(a.isMe?(playerBonus?15:0):0)+(Math.random()-0.5)*16;
    const bs=b.ovr+(Math.random()-0.5)*16;
    return bs-as;
  });
  // limit how bad player can do if ovr is good
  const myPos=rs.grid.findIndex(d=>d.isMe);
  if(rs.grid[0].isMe===false&&Math.random()<playerAdvantage){
    const me=rs.grid.splice(myPos,1)[0];
    const newPos=Math.min(myPos,Math.max(0,myPos+Math.round((Math.random()-.3)*4)));
    rs.grid.splice(newPos,0,me);
  }
}

