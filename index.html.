function upgDriverStat(stat){
  const md=G.myDriver;if(md[stat]>=85){toast('Stat maxed at 85!');return;}
  const cost=Math.round(200+(md[stat]-40)*80);if(G.coins<cost){toast('❌ Not enough coins!');return;}
  G.coins-=cost;md[stat]++;md.xp=(md.xp||0)+30;md.overall=Math.round((md.pace+md.consistency+md.racecraft+md.overtaking)/4);
  if((md.xp||0)%(md.level*200)<30)md.level++;
  md.team=getDriverTeam(md.overall);updateHUD();renderMyDriver();toast(`⬆ ${stat} → ${md[stat]}! OVR ${md.overall}`);
