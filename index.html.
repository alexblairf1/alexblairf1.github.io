cat > /tmp/build_f1.py << 'PYEOF'
html = r"""<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
<title>F1 APEX — Card Manager</title>
<link href="https://fonts.googleapis.com/css2?family=Orbitron:wght@400;700;900&family=Rajdhani:wght@400;600;700&family=Share+Tech+Mono&display=swap" rel="stylesheet">
<style>
:root{
  --red:#e8002d;--red2:#6a0015;--gold:#f5c518;--silver:#b0b0b0;--bronze:#cd7f32;
  --epic:#8b25f0;--epic2:#c47dff;--sp:#ff6500;
