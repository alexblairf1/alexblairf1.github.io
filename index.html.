<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width,initial-scale=1,maximum-scale=1,user-scalable=no">
<title>F1 APEX</title>
<link href="https://fonts.googleapis.com/css2?family=Orbitron:wght@500;700;900&family=Barlow:wght@400;500;600;700&family=Barlow+Condensed:wght@400;600;700&display=swap" rel="stylesheet">
<style>
:root{
  --bg:#06080f;--bg2:#0b0f1c;--bg3:#111828;--bg4:#18223a;
  --border:#1c2840;--border2:#243050;
  --text:#e2eaf6;--dim:#5a7090;--mid:#8da0b8;
  --red:#e8002d;--red2:#a00020;
  --gold:#f5c518;--silver:#c8c8c8;--bronze:#d48c3c;
  --epic:#a040ff;--epic2:#c87aff;
  --special:#ff7a00;
  --green:#00e676;--cyan:#00c8f0;--warn:#ffb300;
  --r:10px;--rt:14px;
}
*{margin:0;padding:0;box-sizing:border-box;-webkit-tap-highlight-color:transparent;}
html,body{height:100%;overflow:hidden;font-family:'Barlow',sans-serif;}
body{background:var(--bg);color:var(--text);display:flex;flex-direction:column;}

/* ── TOP BAR ── */
#topbar{
  height:52px;flex-shrink:0;
  background:linear-gradient(90deg,#06080f,#0d1222,#06080f);
  border-bottom:1.5px solid var(--red2);
  display:flex;align-items:center;padding:0 12px;gap:8px;
  box-shadow:0 2px 30px rgba(232,0,45,.2);
  position:relative;z-index:100;
}
.logo{font-family:'Orbitron',monospace;font-weight:900;font-size:18px;color:var(--red);
  letter-spacing:3px;text-shadow:0 0 20px rgba(232,0,45,.8);flex-shrink:0;}
.logo b{color:var(--cyan);}
.hud-coins,.hud-gems{
  display:flex;align-items:center;gap:3px;
  background:var(--bg3);border:1px solid var(--border2);border-radius:20px;
  padding:3px 9px;font-family:'Orbitron',monospace;font-size:10px;
}
.hud-coins{color:var(--gold);}
.hud-gems{color:var(--epic2);}
.hud-league{
  margin-left:auto;font-family:'Orbitron',monospace;font-size:8px;font-weight:700;
  padding:3px 8px;border-radius:8px;letter-spacing:1px;flex-shrink:0;
}
.hl-br{background:#3d1a00;color:var(--bronze);border:1px solid var(--bronze);}
.hl-si{background:#252530;color:var(--silver);border:1px solid var(--silver);}
.hl-go{background:#2d2200;color:var(--gold);border:1px solid var(--gold);}
.hl-ep{background:#1e0040;color:var(--epic2);border:1px solid var(--epic);}

/* ── MAIN SCROLL ── */
#main{flex:1;overflow-y:auto;overflow-x:hidden;}
#main::-webkit-scrollbar{width:2px;}
#main::-webkit-scrollbar-thumb{background:var(--border);}
.screen{display:none;padding:14px 12px 76px;min-height:100%;}
.screen.active{display:block;}

/* ── BOTTOM NAV ── */
#bnav{
  height:58px;flex-shrink:0;
  background:var(--bg2);border-top:1px solid var(--border);
  display:grid;grid-template-columns:repeat(5,1fr);
}
.nb{
  display:flex;flex-direction:column;align-items:center;justify-content:center;
  gap:2px;background:none;border:none;color:var(--dim);cursor:pointer;
  font-family:'Barlow Condensed',sans-serif;font-size:9px;font-weight:600;
  letter-spacing:.5px;text-transform:uppercase;transition:color .15s;
  padding:6px 0;
}
.nb .ni{font-size:17px;line-height:1;}
.nb.on{color:var(--red);}
.nb.on .ni{filter:drop-shadow(0 0 4px var(--red));}

/* ── TYPOGRAPHY ── */
.sec-head{
  font-family:'Orbitron',monospace;font-size:13px;font-weight:700;
  margin-bottom:12px;display:flex;align-items:center;gap:8px;color:var(--text);
}
.sec-head::before{content:'';width:3px;height:16px;background:var(--red);
  box-shadow:0 0 8px var(--red);border-radius:2px;flex-shrink:0;}

/* ── TIER COLORS (CSS vars on parent) ── */
.t-br{--tc:#d48c3c;--tg:linear-gradient(155deg,#120800,#201000);--ts:0 3px 16px rgba(212,140,60,.25);}
.t-si{--tc:#c8c8c8;--tg:linear-gradient(155deg,#0e0e18,#181828);--ts:0 3px 12px rgba(200,200,200,.12);}
.t-go{--tc:#f5c518;--tg:linear-gradient(155deg,#140f00,#221800);--ts:0 3px 20px rgba(245,197,24,.3);}
.t-ep{--tc:#a040ff;--tg:linear-gradient(155deg,#0c0020,#180038);--ts:0 4px 24px rgba(160,64,255,.45);}
.t-sp{--tc:#ff7a00;--tg:linear-gradient(155deg,#140004,#220008);--ts:0 4px 24px rgba(255,122,0,.4),inset 0 0 40px rgba(232,0,45,.04);}

/* ── TIER BADGE ── */
.tbadge{font-family:'Orbitron',monospace;font-size:7px;font-weight:700;
  letter-spacing:1.2px;padding:2px 5px;border-radius:3px;display:inline-block;}
.tbr{background:#3d1a00;color:var(--bronze);border:1px solid var(--bronze);}
.tsi{background:#202028;color:#ccc;border:1px solid #808080;}
.tgo{background:#2d2000;color:var(--gold);border:1px solid var(--gold);}
.tep{background:#1e0040;color:var(--epic2);border:1px solid var(--epic);box-shadow:0 0 8px rgba(160,64,255,.3);}
.tsp{background:#280004;color:var(--special);border:1px solid var(--special);box-shadow:0 0 8px rgba(255,122,0,.3);}

/* ═══════════════════════════════════════
   DRIVER / CAR CARD  (small – 120×172)
═══════════════════════════════════════ */
.dcard{
  width:120px;height:172px;border-radius:var(--r);position:relative;
  overflow:hidden;cursor:pointer;flex-shrink:0;
  transition:transform .18s;
  border:1.5px solid var(--tc,#333);
  background:var(--tg);box-shadow:var(--ts);
}
.dcard:hover{transform:translateY(-4px) scale(1.04);}
.dcard .stripe{position:absolute;top:0;left:0;right:0;height:3px;border-radius:var(--r) var(--r) 0 0;}
.dcard-in{padding:7px;height:100%;display:flex;flex-direction:column;}
.dcard-badge{position:absolute;top:6px;left:6px;}
.dcard-emo{font-size:38px;text-align:center;margin:10px 0 2px;line-height:1;}
.dcard-name{font-family:'Orbitron',monospace;font-size:7px;font-weight:700;
  text-align:center;text-transform:uppercase;line-height:1.3;color:var(--text);}
.dcard-team{font-size:8px;text-align:center;color:var(--dim);margin:2px 0;}
.dcard-num{font-family:'Orbitron',monospace;font-size:30px;font-weight:900;
  opacity:.1;position:absolute;bottom:28px;right:4px;line-height:1;color:var(--tc);}
.dcard-stats{display:grid;grid-template-columns:1fr 1fr;gap:1px;
  margin-top:auto;padding-top:3px;border-top:1px solid rgba(255,255,255,.06);}
.dcard-sv{font-family:'Orbitron',monospace;font-size:11px;font-weight:700;
  text-align:center;color:var(--tc);line-height:1.1;}
.dcard-sl{font-size:6px;color:var(--dim);text-align:center;text-transform:uppercase;}
.dcard-special{position:absolute;bottom:5px;left:0;right:0;text-align:center;
  font-size:6px;font-family:'Orbitron',monospace;color:var(--tc);
  text-shadow:0 0 6px currentColor;letter-spacing:.6px;}

/* ── HORIZONTAL SCROLL ── */
.hscroll{display:flex;gap:10px;overflow-x:auto;padding-bottom:6px;scrollbar-width:none;}
.hscroll::-webkit-scrollbar{display:none;}

/* ═══════════════════════════════════════
   HOME
═══════════════════════════════════════ */
.hero{
  background:linear-gradient(135deg,#080014,#120020,#060010);
  border:1px solid #280050;border-radius:var(--rt);
  padding:18px 16px;margin-bottom:16px;position:relative;overflow:hidden;
  box-shadow:0 0 50px rgba(160,64,255,.12);
}
.hero::after{content:'🏎';font-size:80px;position:absolute;right:-8px;bottom:-8px;
  opacity:.08;transform:scaleX(-1);}
.hero h1{font-family:'Orbitron',monospace;font-size:20px;font-weight:900;line-height:1.15;}
.hero h1 em{color:var(--red);font-style:normal;text-shadow:0 0 15px rgba(232,0,45,.8);}
.hero-sub{font-size:12px;color:var(--mid);margin:7px 0 14px;line-height:1.5;}

/* XP bar */
.xp-bar-wrap{background:var(--bg3);border:1px solid var(--border2);border-radius:10px;
  padding:10px 12px;margin-bottom:14px;}
.xp-row{display:flex;justify-content:space-between;align-items:center;margin-bottom:6px;}
.xp-label{font-family:'Orbitron',monospace;font-size:10px;font-weight:700;}
.xp-track{height:6px;background:rgba(255,255,255,.06);border-radius:3px;overflow:hidden;}
.xp-fill{height:100%;border-radius:3px;transition:width .5s ease;}

/* Quick grid */
.qgrid{display:grid;grid-template-columns:1fr 1fr;gap:9px;margin-bottom:16px;}
.qcard{background:var(--bg3);border:1px solid var(--border);border-radius:var(--r);
  padding:13px 12px;cursor:pointer;transition:all .18s;display:flex;flex-direction:column;gap:5px;}
.qcard:hover{border-color:var(--red);background:rgba(232,0,45,.04);}
.qcard .qi{font-size:22px;}
.qcard .qt{font-family:'Orbitron',monospace;font-size:10px;font-weight:700;}
.qcard .qs{font-size:11px;color:var(--dim);}

/* Objectives */
.obj-item{background:var(--bg3);border:1px solid var(--border);border-radius:var(--r);
  padding:11px 12px;display:flex;align-items:center;gap:10px;margin-bottom:7px;}
.obj-icon{font-size:18px;flex-shrink:0;}
.obj-text{flex:1;font-size:12px;font-weight:500;}
.obj-done .obj-text{text-decoration:line-through;color:var(--dim);}
.obj-reward{font-family:'Orbitron',monospace;font-size:9px;color:var(--gold);flex-shrink:0;}

/* ═══════════════════════════════════════
   TEAM VIEW
═══════════════════════════════════════ */
.team-stat-row{display:grid;grid-template-columns:repeat(4,1fr);gap:8px;margin-bottom:14px;}
.tstat{background:var(--bg3);border:1px solid var(--border);border-radius:8px;
  padding:9px 6px;text-align:center;}
.tstat-v{font-family:'Orbitron',monospace;font-size:18px;font-weight:700;}
.tstat-l{font-size:9px;color:var(--dim);text-transform:uppercase;letter-spacing:.3px;margin-top:2px;}

.team-slot{background:var(--bg3);border:1.5px dashed var(--border);border-radius:var(--r);
  padding:12px;display:flex;align-items:center;gap:10px;cursor:pointer;
  transition:all .18s;margin-bottom:8px;}
.team-slot:hover{border-color:var(--cyan);border-style:solid;}
.team-slot.filled{border-style:solid;border-color:var(--border2);}
.team-slot.filled:hover{border-color:var(--cyan);}
.slot-emo{font-size:28px;flex-shrink:0;}
.slot-info{flex:1;}
.slot-name{font-family:'Orbitron',monospace;font-size:11px;font-weight:700;}
.slot-sub{font-size:10px;color:var(--dim);margin-top:2px;}
.slot-lbl{font-size:9px;text-transform:uppercase;letter-spacing:.8px;color:var(--dim);
  font-family:'Barlow Condensed',sans-serif;margin-bottom:4px;}

/* ═══════════════════════════════════════
   PACKS
═══════════════════════════════════════ */
.pack-section{margin-bottom:20px;}
.pack-section-title{font-family:'Barlow Condensed',sans-serif;font-size:11px;
  font-weight:700;color:var(--dim);text-transform:uppercase;letter-spacing:1.5px;
  margin-bottom:8px;}
.pack-row{display:flex;gap:9px;overflow-x:auto;padding-bottom:4px;scrollbar-width:none;}
.pack-row::-webkit-scrollbar{display:none;}
.pack-tile{
  flex-shrink:0;width:130px;
  background:var(--bg3);border:1.5px solid var(--border);border-radius:var(--rt);
  padding:13px 10px;text-align:center;cursor:pointer;transition:all .2s;
  position:relative;overflow:hidden;
}
.pack-tile::before{content:'';position:absolute;inset:0;opacity:0;
  transition:opacity .2s;border-radius:var(--rt);}
.pack-tile:hover::before{opacity:1;}
.pack-tile:hover{transform:translateY(-3px);}
.pack-tile.pk-br{border-color:var(--bronze);} .pack-tile.pk-br::before{background:radial-gradient(circle,rgba(212,140,60,.15),transparent);}
.pack-tile.pk-si{border-color:#888;} .pack-tile.pk-si::before{background:radial-gradient(circle,rgba(200,200,200,.1),transparent);}
.pack-tile.pk-go{border-color:var(--gold);box-shadow:0 0 16px rgba(245,197,24,.15);} .pack-tile.pk-go::before{background:radial-gradient(circle,rgba(245,197,24,.15),transparent);}
.pack-tile.pk-ep{border-color:var(--epic);box-shadow:0 0 20px rgba(160,64,255,.2);} .pack-tile.pk-ep::before{background:radial-gradient(circle,rgba(160,64,255,.2),transparent);}
.pack-tile.pk-sp{border-color:var(--special);box-shadow:0 0 20px rgba(255,122,0,.2);} .pack-tile.pk-sp::before{background:radial-gradient(circle,rgba(255,122,0,.18),transparent);}
.pack-tile.locked{opacity:.35;cursor:not-allowed;filter:grayscale(.5);}
.pk-icon{font-size:36px;display:block;margin-bottom:6px;}
.pk-name{font-family:'Orbitron',monospace;font-size:9px;font-weight:700;margin-bottom:3px;}
.pack-tile.pk-br .pk-name{color:var(--bronze);}.pack-tile.pk-si .pk-name{color:var(--silver);}
.pack-tile.pk-go .pk-name{color:var(--gold);}.pack-tile.pk-ep .pk-name{color:var(--epic2);}
.pack-tile.pk-sp .pk-name{color:var(--special);}
.pk-desc{font-size:8.5px;color:var(--dim);line-height:1.5;margin-bottom:7px;}
.pk-cost{font-family:'Orbitron',monospace;font-size:10px;}
.pk-lock-reason{font-size:7.5px;color:var(--red);margin-top:3px;font-family:'Orbitron',monospace;}
.pk-free{font-family:'Orbitron',monospace;font-size:10px;color:var(--green);}

/* ═══════════════════════════════════════
   COLLECTION (big grid cards)
═══════════════════════════════════════ */
.filter-row{display:flex;gap:6px;overflow-x:auto;margin-bottom:12px;
  padding-bottom:3px;scrollbar-width:none;}
.filter-row::-webkit-scrollbar{display:none;}
.ftab{flex-shrink:0;background:var(--bg3);border:1px solid var(--border);
  border-radius:16px;padding:4px 12px;font-size:11px;font-weight:600;
  color:var(--dim);cursor:pointer;transition:all .15s;}
.ftab.on,.ftab:hover{background:var(--red);border-color:var(--red);color:#fff;}

.col-grid{display:grid;grid-template-columns:repeat(2,1fr);gap:10px;}
.col-card{
  border-radius:var(--rt);border:1.5px solid var(--tc,#333);
  background:var(--tg);box-shadow:var(--ts);
  position:relative;overflow:hidden;cursor:pointer;
  transition:transform .18s;padding-bottom:8px;
}
.col-card:hover{transform:translateY(-4px) scale(1.02);}
.col-stripe{height:3px;border-radius:var(--rt) var(--rt) 0 0;}
.col-top{padding:8px 8px 4px;display:flex;align-items:flex-start;justify-content:space-between;}
.col-emo{font-size:50px;display:block;text-align:center;margin:4px 0;}
.col-name{font-family:'Orbitron',monospace;font-size:8px;font-weight:700;
  text-align:center;text-transform:uppercase;padding:0 6px;line-height:1.3;}
.col-team{font-size:9px;color:var(--dim);text-align:center;padding:2px 6px;}
.col-ovr{font-family:'Orbitron',monospace;font-size:24px;font-weight:900;
  text-align:center;color:var(--tc);text-shadow:0 0 12px var(--tc);
  margin:2px 0;line-height:1;}
.col-stats{display:grid;grid-template-columns:repeat(3,1fr);gap:2px;padding:0 6px;}
.col-sv{font-family:'Orbitron',monospace;font-size:10px;font-weight:700;
  text-align:center;color:var(--tc);}
.col-sl{font-size:7px;color:var(--dim);text-align:center;text-transform:uppercase;}
.col-special{text-align:center;font-size:6.5px;font-family:'Orbitron',monospace;
  color:var(--tc);padding:3px 6px 0;letter-spacing:.5px;}
.upgrade-btn{
  margin:6px 6px 0;width:calc(100% - 12px);
  background:rgba(255,255,255,.04);border:1px solid rgba(255,255,255,.08);
  border-radius:6px;padding:5px;font-family:'Orbitron',monospace;
  font-size:8px;color:var(--mid);cursor:pointer;text-align:center;
  transition:all .18s;
}
.upgrade-btn:hover{background:rgba(245,197,24,.1);border-color:var(--gold);color:var(--gold);}

/* ═══════════════════════════════════════
   SEASON
═══════════════════════════════════════ */
.league-tabs{display:flex;gap:6px;margin-bottom:14px;overflow-x:auto;
  padding-bottom:3px;scrollbar-width:none;}
.league-tabs::-webkit-scrollbar{display:none;}
.ltab{flex-shrink:0;font-family:'Orbitron',monospace;font-size:9px;font-weight:700;
  padding:5px 12px;border-radius:16px;cursor:pointer;transition:all .18s;
  border:1.5px solid var(--border);color:var(--dim);background:var(--bg3);}
.ltab.on,.ltab:hover:not(.lk){color:#fff;}
.ltab.on.br,.ltab.br:hover:not(.lk){background:#3d1800;border-color:var(--bronze);color:var(--bronze);}
.ltab.on.si,.ltab.si:hover:not(.lk){background:#252530;border-color:var(--silver);color:var(--silver);}
.ltab.on.go,.ltab.go:hover:not(.lk){background:#2d2000;border-color:var(--gold);color:var(--gold);}
.ltab.on.ep,.ltab.ep:hover:not(.lk){background:#1e0040;border-color:var(--epic);color:var(--epic2);}
.ltab.lk{opacity:.4;cursor:not-allowed;}

.season-banner{background:var(--bg3);border:1px solid var(--border2);border-radius:var(--rt);
  padding:13px;margin-bottom:14px;}
.sb-title{font-family:'Orbitron',monospace;font-size:14px;font-weight:700;margin-bottom:4px;}
.sb-meta{font-size:11px;color:var(--dim);margin-bottom:6px;}
.sb-prog{height:5px;background:rgba(255,255,255,.06);border-radius:3px;overflow:hidden;margin-bottom:8px;}
.sb-fill{height:100%;border-radius:3px;transition:width .5s;}
.sb-rewards{display:flex;gap:8px;flex-wrap:wrap;}
.sb-rew{font-size:9px;font-family:'Orbitron',monospace;padding:2px 8px;
  border-radius:10px;border:1px solid rgba(255,255,255,.08);color:var(--mid);}

/* leaderboard */
.lboard{background:var(--bg3);border:1px solid var(--border);border-radius:var(--rt);
  padding:12px;margin-bottom:14px;}
.lboard-title{font-family:'Orbitron',monospace;font-size:10px;font-weight:700;
  color:var(--dim);margin-bottom:9px;letter-spacing:1px;}
.lb-row{display:flex;align-items:center;gap:8px;padding:6px 0;
  border-bottom:1px solid rgba(255,255,255,.04);}
.lb-row:last-child{border:none;}
.lb-pos{font-family:'Orbitron',monospace;font-size:13px;font-weight:700;
  min-width:22px;text-align:center;}
.lb-row.me{background:rgba(0,200,240,.04);border-radius:6px;padding:6px 4px;margin:0 -4px;}
.lb-name{flex:1;font-size:12px;font-weight:600;}
.lb-pts{font-family:'Orbitron',monospace;font-size:11px;color:var(--gold);}

.race-card{background:var(--bg3);border:1px solid var(--border);border-radius:var(--r);
  padding:12px;display:flex;align-items:center;gap:10px;margin-bottom:8px;
  cursor:pointer;transition:all .18s;position:relative;overflow:hidden;}
.race-card:hover:not(.rc-locked){border-color:var(--red);}
.race-card.rc-done{border-color:var(--green);opacity:.6;}
.race-card.rc-next{border-color:var(--gold);box-shadow:0 0 15px rgba(245,197,24,.15);}
.race-card.rc-locked{opacity:.35;cursor:not-allowed;}
.rc-flag{font-size:24px;flex-shrink:0;}
.rc-info{flex:1;}
.rc-name{font-family:'Orbitron',monospace;font-size:10px;font-weight:700;}
.rc-sub{font-size:10px;color:var(--dim);margin-top:2px;}
.rc-rew{text-align:right;}
.rc-coins{font-family:'Orbitron',monospace;font-size:10px;color:var(--gold);}
.rc-pts{font-size:9px;color:var(--dim);}
.rc-status{position:absolute;top:6px;right:8px;font-family:'Orbitron',monospace;font-size:9px;}
.rc-status.done{color:var(--green);}
.rc-status.go{color:var(--gold);animation:pulse 1.8s infinite;}
.req-note{font-size:8px;color:var(--red);font-family:'Orbitron',monospace;
  position:absolute;bottom:0;left:0;right:0;background:rgba(232,0,45,.1);
  padding:2px 10px;text-align:center;}

@keyframes pulse{0%,100%{opacity:1}50%{opacity:.4}}

/* ═══════════════════════════════════════
   EVENTS
═══════════════════════════════════════ */
.ev-card{background:var(--bg3);border:1px solid var(--border);border-radius:var(--rt);
  padding:14px;margin-bottom:10px;cursor:pointer;transition:all .18s;
  position:relative;overflow:hidden;}
.ev-card:hover{border-color:var(--red);}
.ev-card.ev-special{border-color:var(--special);box-shadow:0 0 18px rgba(255,122,0,.15);}
.ev-card.ev-weekly{border-color:var(--epic);}
.ev-card.ev-daily{border-color:var(--cyan);}
.ev-head{display:flex;align-items:center;gap:10px;margin-bottom:8px;}
.ev-icon{font-size:26px;}
.ev-title{font-family:'Orbitron',monospace;font-size:11px;font-weight:700;}
.ev-type{font-size:9px;color:var(--dim);letter-spacing:.8px;text-transform:uppercase;margin-top:2px;}
.ev-desc{font-size:11px;color:var(--mid);line-height:1.55;margin-bottom:8px;}
.ev-rews{display:flex;gap:6px;flex-wrap:wrap;}
.ev-rew{font-size:9px;font-family:'Orbitron',monospace;padding:2px 8px;
  border-radius:10px;border:1px solid rgba(255,255,255,.08);color:var(--mid);}
.ev-rew.gold{color:var(--gold);border-color:rgba(245,197,24,.25);}
.ev-rew.purple{color:var(--epic2);border-color:rgba(160,64,255,.25);}
.ev-rew.green{color:var(--green);border-color:rgba(0,230,118,.25);}
.ev-locked-bar{font-size:8.5px;font-family:'Orbitron',monospace;color:var(--red);
  margin-top:8px;padding:3px 0 0;border-top:1px solid rgba(232,0,45,.15);}
.lim-badge{position:absolute;top:10px;right:10px;background:var(--red);color:#fff;
  font-size:7px;font-family:'Orbitron',monospace;padding:2px 6px;border-radius:8px;
  letter-spacing:1px;animation:pulse 2s infinite;}

/* ═══════════════════════════════════════
   RACE SCREEN (full-page overlay)
═══════════════════════════════════════ */
#race-over{display:none;position:fixed;inset:0;background:var(--bg);
  z-index:500;flex-direction:column;overflow-y:auto;}
#race-over.show{display:flex;}
.race-wrap{flex:1;padding:14px 12px 24px;display:flex;flex-direction:column;gap:12px;}

.race-hud{display:flex;justify-content:space-between;align-items:center;
  padding-top:4px;}
.race-title{font-family:'Orbitron',monospace;font-size:13px;font-weight:700;color:var(--red);}
.race-lap{font-family:'Barlow Condensed',monospace;font-size:13px;color:var(--dim);}

/* Visual track */
.race-track{background:linear-gradient(135deg,#0c1530,#162040);
  border:1px solid var(--border);border-radius:var(--rt);
  height:150px;position:relative;overflow:hidden;}
.race-track::before{content:'';position:absolute;inset:16px;
  border:1.5px dashed rgba(255,255,255,.05);border-radius:60px;}
.race-car-dot{font-size:26px;position:absolute;
  transition:all .6s cubic-bezier(.4,0,.2,1);
  filter:drop-shadow(0 0 8px var(--red));}

/* Positions */
.pos-table{display:flex;flex-direction:column;gap:5px;}
.pos-row{display:flex;align-items:center;gap:8px;padding:7px 10px;
  background:var(--bg3);border:1px solid var(--border);border-radius:8px;}
.pos-row.me{border-color:var(--cyan);background:rgba(0,200,240,.04);}
.pos-num{font-family:'Orbitron',monospace;font-size:14px;font-weight:900;min-width:24px;}
.pos-row:nth-child(1) .pos-num{color:var(--gold);}
.pos-row:nth-child(2) .pos-num{color:var(--silver);}
.pos-row:nth-child(3) .pos-num{color:var(--bronze);}
.pos-name{flex:1;font-size:12px;font-weight:600;}
.pos-gap{font-family:'Barlow Condensed',monospace;font-size:11px;color:var(--dim);}

/* Decision banner */
.decision-box{background:linear-gradient(135deg,#0e1830,#182848);
  border:1.5px solid var(--warn);border-radius:var(--rt);padding:14px;
  box-shadow:0 0 20px rgba(255,179,0,.15);}
.decision-title{font-family:'Orbitron',monospace;font-size:12px;font-weight:700;
  color:var(--warn);margin-bottom:6px;}
.decision-desc{font-size:11px;color:var(--mid);margin-bottom:12px;line-height:1.5;}
.decision-opts{display:flex;flex-direction:column;gap:7px;}
.dopt{background:var(--bg3);border:1.5px solid var(--border2);border-radius:8px;
  padding:10px 12px;cursor:pointer;transition:all .18s;display:flex;align-items:center;gap:10px;}
.dopt:hover{border-color:var(--cyan);}
.dopt-icon{font-size:20px;flex-shrink:0;}
.dopt-info{flex:1;}
.dopt-name{font-family:'Orbitron',monospace;font-size:10px;font-weight:700;}
.dopt-sub{font-size:10px;color:var(--dim);margin-top:2px;}
.dopt-odds{font-size:9px;font-family:'Orbitron',monospace;margin-top:2px;}
.dopt-odds.good{color:var(--green);}
.dopt-odds.risk{color:var(--warn);}
.dopt-odds.danger{color:var(--red);}

/* Race log */
.race-log{background:var(--bg3);border:1px solid var(--border);border-radius:8px;
  padding:9px;font-size:10px;color:var(--dim);max-height:80px;overflow-y:auto;
  font-family:'Barlow Condensed',sans-serif;line-height:1.6;}
.rl-item{margin-bottom:1px;}
.rl-item.hi{color:var(--cyan);}
.rl-item.ok{color:var(--green);}
.rl-item.bad{color:var(--red);}
.rl-item.warn{color:var(--warn);}

/* Race result */
.result-box{background:var(--bg3);border:1px solid var(--border2);border-radius:var(--rt);
  padding:20px;text-align:center;}
.result-pos{font-family:'Orbitron',monospace;font-size:48px;font-weight:900;line-height:1;}
.result-label{font-size:14px;color:var(--mid);margin-bottom:16px;}
.result-rewards{display:grid;grid-template-columns:repeat(3,1fr);gap:8px;margin-bottom:16px;}
.rrew{background:var(--bg4);border:1px solid var(--border);border-radius:8px;padding:8px;text-align:center;}
.rrew-v{font-family:'Orbitron',monospace;font-size:14px;font-weight:700;}
.rrew-l{font-size:9px;color:var(--dim);margin-top:2px;text-transform:uppercase;}

/* Pack choice (pick 1 of 3) */
.pick-overlay{display:none;position:fixed;inset:0;background:rgba(0,0,0,.96);
  z-index:600;align-items:center;justify-content:center;flex-direction:column;gap:14px;padding:20px;}
.pick-overlay.show{display:flex;}
.pick-title{font-family:'Orbitron',monospace;font-size:16px;font-weight:700;color:var(--text);
  text-align:center;margin-bottom:4px;}
.pick-sub{font-size:12px;color:var(--dim);text-align:center;}
.pick-cards{display:flex;gap:14px;justify-content:center;flex-wrap:wrap;}

/* ═══════════════════════════════════════
   PACK OPENING
═══════════════════════════════════════ */
.pack-open-over{display:none;position:fixed;inset:0;background:rgba(0,0,0,.97);
  z-index:600;align-items:center;justify-content:center;flex-direction:column;gap:16px;}
.pack-open-over.show{display:flex;}
@keyframes cardPop{0%{transform:scale(0) rotateY(180deg);opacity:0}
  70%{transform:scale(1.3) rotateY(0deg);opacity:1}100%{transform:scale(1.2);opacity:1}}
.card-reveal{animation:cardPop .6s cubic-bezier(.34,1.56,.64,1) forwards;}
.pack-card-name{font-family:'Orbitron',monospace;font-size:14px;font-weight:700;text-align:center;}
.pack-card-sub{font-size:11px;color:var(--dim);text-align:center;}

/* ═══════════════════════════════════════
   MODALS (bottom sheet)
═══════════════════════════════════════ */
.modal-over{display:none;position:fixed;inset:0;background:rgba(0,0,0,.88);
  z-index:400;align-items:flex-end;justify-content:center;}
.modal-over.show{display:flex;}
.modal-sheet{background:var(--bg2);border:1px solid var(--border2);
  border-radius:18px 18px 0 0;width:100%;max-width:520px;
  padding:16px 14px 24px;max-height:85vh;overflow-y:auto;
  animation:slideUp .3s cubic-bezier(.34,1.56,.64,1);}
@keyframes slideUp{from{transform:translateY(100%)}to{transform:translateY(0)}}
.modal-handle{width:36px;height:4px;background:var(--border);
  border-radius:2px;margin:0 auto 16px;}
.modal-title{font-family:'Orbitron',monospace;font-size:14px;font-weight:700;
  margin-bottom:14px;display:flex;align-items:center;gap:8px;}
.modal-close{margin-left:auto;background:none;border:none;color:var(--dim);
  font-size:18px;cursor:pointer;line-height:1;}
.modal-close:hover{color:var(--red);}

/* Card detail */
.cd-statbar-row{display:flex;align-items:center;gap:8px;margin-bottom:6px;}
.cd-statbar-label{font-size:10px;color:var(--dim);width:90px;text-transform:uppercase;
  letter-spacing:.3px;font-family:'Barlow Condensed',sans-serif;}
.cd-statbar-track{flex:1;height:5px;background:rgba(255,255,255,.06);
  border-radius:3px;overflow:hidden;}
.cd-statbar-fill{height:100%;border-radius:3px;}
.cd-statbar-val{font-family:'Orbitron',monospace;font-size:10px;min-width:24px;text-align:right;}

/* Select grid */
.sel-grid{display:grid;grid-template-columns:repeat(2,1fr);gap:8px;
  max-height:50vh;overflow-y:auto;}
.sel-item{background:var(--bg3);border:1.5px solid var(--border);border-radius:var(--r);
  padding:10px 8px;cursor:pointer;transition:all .18s;display:flex;align-items:center;gap:8px;}
.sel-item:hover{border-color:var(--cyan);}
.sel-item .si-emo{font-size:24px;}
.sel-item .si-name{font-family:'Orbitron',monospace;font-size:9px;font-weight:700;line-height:1.3;}
.sel-item .si-sub{font-size:9px;color:var(--dim);margin-top:1px;}
.sel-item .si-ovr{font-family:'Orbitron',monospace;font-size:14px;font-weight:700;
  margin-left:auto;color:var(--tc,#888);}

/* ── MY DRIVER ── */
.md-section{background:var(--bg3);border:1px solid var(--border2);
  border-radius:var(--rt);padding:14px;margin-bottom:12px;}
.md-title{font-family:'Orbitron',monospace;font-size:11px;font-weight:700;
  margin-bottom:10px;color:var(--dim);letter-spacing:1px;}
.md-stat-row{display:flex;align-items:center;gap:8px;margin-bottom:6px;}
.md-stat-name{font-size:11px;color:var(--mid);width:90px;flex-shrink:0;}
.md-stat-bar{flex:1;height:6px;background:rgba(255,255,255,.06);border-radius:3px;overflow:hidden;}
.md-stat-fill{height:100%;background:var(--cyan);border-radius:3px;transition:width .4s;}
.md-stat-val{font-family:'Orbitron',monospace;font-size:11px;color:var(--cyan);min-width:26px;text-align:right;}
.md-team{display:flex;align-items:center;gap:8px;padding:8px;background:var(--bg4);
  border-radius:8px;margin-bottom:8px;}
.md-team-color{width:16px;height:16px;border-radius:50%;}
.md-team-name{font-size:12px;font-weight:600;}
.md-upgrade-cost{font-size:10px;color:var(--dim);margin-top:4px;}

/* TOAST */
#toast{position:fixed;bottom:68px;left:50%;transform:translateX(-50%) translateY(10px);
  background:var(--bg3);border:1px solid var(--border2);border-radius:20px;
  padding:8px 18px;font-size:12px;font-weight:600;color:var(--text);
  z-index:800;opacity:0;pointer-events:none;white-space:nowrap;
  transition:all .25s;box-shadow:0 4px 20px rgba(0,0,0,.5);}
#toast.show{opacity:1;transform:translateX(-50%) translateY(0);}

/* CONFIRM */
.confirm-over{display:none;position:fixed;inset:0;background:rgba(0,0,0,.9);
  z-index:700;align-items:center;justify-content:center;padding:20px;}
.confirm-over.show{display:flex;}
.confirm-box{background:var(--bg2);border:1px solid var(--border2);border-radius:var(--rt);
  padding:22px;max-width:300px;width:100%;text-align:center;}
.confirm-box h3{font-family:'Orbitron',monospace;font-size:15px;font-weight:700;margin-bottom:8px;}
.confirm-box p{font-size:12px;color:var(--mid);margin-bottom:18px;line-height:1.5;}
.confirm-btns{display:flex;gap:8px;justify-content:center;}

/* BUTTONS */
.btn{display:inline-flex;align-items:center;justify-content:center;gap:6px;border:none;
  border-radius:8px;padding:9px 18px;font-family:'Orbitron',monospace;font-size:11px;
  font-weight:700;letter-spacing:.8px;cursor:pointer;transition:all .18s;text-transform:uppercase;}
.btn.full{width:100%;}
.btn-red{background:var(--red);color:#fff;box-shadow:0 4px 16px rgba(232,0,45,.35);}
.btn-red:hover{background:#ff1a3d;transform:translateY(-1px);}
.btn-cyan{background:transparent;color:var(--cyan);border:1.5px solid var(--cyan);}
.btn-cyan:hover{background:rgba(0,200,240,.08);}
.btn-gold{background:linear-gradient(135deg,#8b6914,#f5c518);color:#1a0f00;}
.btn-ep{background:linear-gradient(135deg,#4a0090,#9b30ff);color:#f0e0ff;}
.btn-dim{background:var(--bg3);color:var(--dim);border:1px solid var(--border);}
.btn-green{background:var(--green);color:#000;}
.btn-sm{padding:6px 12px;font-size:9px;}
</style>
</head>
<body>

<!-- TOP BAR -->
