function renderUpgrades(){
  const ul=document.getElementById('upgrade-list');ul.innerHTML='';
  const upgradeable=[...G.col,...G.cars].filter(c=>G.dupes[c.id]>0||(G.upgrades[c.id]||0)>0);
  if(!upgradeable.length){ul.innerHTML=`<div style="color:var(--dim);font-size:12px;text-align:center;padding:20px">Get duplicate cards to unlock upgrades.</div>`;return;}
  upgradeable.forEach(card=>{
    const lvl=G.upgrades[card.id]||0;const dups=G.dupes[card.id]||0;const cost=getUpgCost(card,lvl);const canUp=lvl<5&&dups>0&&G.coins>=cost;
    const div=document.createElement('div');div.className='upg-card';
    div.innerHTML=`<div class="upg-emo">${card.emoji}</div><div class="upg-info"><div class="upg-name">${card.name} <span class="tb ${TIER[card.tier]?.badge}">${TIER[card.tier]?.label}</span></div><div class="upg-sub">LV ${lvl}/5 · ${dups} dupe(s)</div><div class="prog-wrap" style="margin-top:4px"><div class="prog-fill prog-green" style="width:${lvl*20}%"></div></div></div><div style="text-align:right">${lvl<5?`<div class="upg-cost">🪙${numFmt(cost)}</div><button class="btn ${canUp?'btn-green':'btn-dim'} btn-sm" style="margin-top:4px" onclick="upgradeCard('${card.id}')" ${canUp?'':'disabled'}>UP ▲</button>`:'<div style="font-size:9px;color:var(--green);font-family:Orbitron,monospace">MAX</div>'}</div>`;
    ul.appendChild(div);
  });
}
function getUpgCost(card,lvl){const base={br:400,si:1200,go:3500,ep:9000,sp:20000};return (base[card.tier]||400)*(lvl+1);}
function upgradeCard(id){
  const card=[...G.col,...G.cars].find(c=>c.id===id);if(!card)return;
  const lvl=G.upgrades[id]||0;if(lvl>=5){toast('Card is max level!');return;}
  if((G.dupes[id]||0)<1){toast('Need duplicate card!');return;}
  const cost=getUpgCost(card,lvl);if(G.coins<cost){toast('❌ Not enough coins!');return;}
  G.coins-=cost;G.upgrades[id]=(G.upgrades[id]||0)+1;G.dupes[id]--;
  updateHUD();renderTeam();toast(`⬆ ${card.name} → LV ${G.upgrades[id]}!`);
  if(G.upgrades[id]>=3)completeGoal('g5');
}
function openSel(slot){
