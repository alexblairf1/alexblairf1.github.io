function makeSmCard(d){const el=document.createElement('div');el.className=`dc dc-sm ${d.tier||'br'}`;el.innerHTML=cardHtml(d,false);el.onclick=()=>showCardDetail(d);return el;}
function makeLgCard(d){const el=document.createElement('div');el.className=`dc dc-lg ${d.tier||'br'}`;el.innerHTML=cardHtml(d,true);el.onclick=()=>showCardDetail(d);return el;}

function showCardDetail(d){
