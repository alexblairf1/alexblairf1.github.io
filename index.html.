function doOvertake(){
  if(RS.overtakeCooldown>0){toast('⏱ Overtake cooling down!');return;}
  if(!RS.running||RS.dnf){return;}
  if(RS.playerPos<=1){toast("You're already in P1!");return;}

  const otBtn=document.getElementById('btn-overtake');
  // How close are we?
  const closeEnough=RS.aheadGap<2.0;
  // Player card overtaking stat bonus
  const player=G.team.d1||G.team.d2;
  const otStat=player?(player.overtaking+(G.upgrades[player.id]||0))/100:0.7;
  const carBonus=G.team.car?(G.team.car.speed/100)*0.15:0;
  // Base success chance — needs to be close AND have good stat
  let successChance=closeEnough?(0.45+otStat*0.3+carBonus):(0.15+otStat*0.2);
  // Penalty if too far
  if(RS.aheadGap>4)successChance*=0.3;
  const roll=Math.random();
  if(roll<successChance){
    // SUCCESS
    RS.playerPos=Math.max(1,RS.playerPos-1);
    RS.aheadGap=Math.random()*1.5+0.5;// Now close to new car ahead
    RS.behindGap=0.3+Math.random()*0.8;// Old ahead car now behind us
    RS.overtakesThisRace++;
    addRaceLog('⚡ OVERTAKE COMPLETE! Gained a position!','ok');
    flashTrack('ok');
    updateRaceUI();updateCarPositions();
  } else {
    // FAILED — different outcomes
    const badRoll=Math.random();
    if(badRoll<0.4){// Just failed, lost ground
      RS.aheadGap=Math.min(15,RS.aheadGap+1.8);
      addRaceLog('❌ Overtake failed — lost ground!','dan');
      flashTrack('fail');
    } else if(badRoll<0.7){// Wide, lost time
      RS.aheadGap=Math.min(15,RS.aheadGap+3.0);
      RS.behindGap=Math.max(0.1,RS.behindGap-1.5);
      addRaceLog('❌ Went wide! Lost 2 positions of gap','dan');
      flashTrack('fail');
    } else {// Near miss — ok
      RS.aheadGap=Math.min(15,RS.aheadGap+0.8);
      addRaceLog('⚠️ Close but no cigar — gap lost slightly','warn');
    }
    updateRaceUI();updateCarPositions();
  }
  // Start cooldown
  RS.overtakeCooldown=RS.otCoolMax;
  otBtn.classList.add('cooling');
  const coolbar=document.getElementById('ot-coolbar');if(coolbar)coolbar.style.width='100%';
  RS.otTimer=setInterval(()=>{
    RS.overtakeCooldown=Math.max(0,RS.overtakeCooldown-100);
    const pct=(RS.overtakeCooldown/RS.otCoolMax)*100;
    if(coolbar)coolbar.style.width=pct+'%';
    if(RS.overtakeCooldown<=0){clearInterval(RS.otTimer);otBtn.classList.remove('cooling');if(coolbar)coolbar.style.width='0%';}
  },100);
}

function doDefend(){
  if(RS.defendCooldown>0){toast('⏱ Defense cooling down!');return;}
  if(!RS.running||RS.dnf)return;

  const defBtn=document.getElementById('btn-defend');
  const player=G.team.d1||G.team.d2;
  const defStat=player?(player.racecraft+(G.upgrades[player.id]||0))/100:0.7;
  const successChance=0.6+defStat*0.25;
  if(Math.random()<successChance){
    RS.behindGap=Math.min(20,RS.behindGap+2.5);
    addRaceLog('🛡 Defense successful! Kept position!','ok');
    flashTrack('ok');
  } else {
    addRaceLog('⚠️ Defense partially failed — gap compressed','warn');
    RS.behindGap=Math.max(0.1,RS.behindGap-0.5);
  }
  RS.defenseThisRace++;
  updateRaceUI();updateCarPositions();
  RS.defendCooldown=RS.defCoolMax;
  defBtn.classList.add('cooling');
  const coolbar=document.getElementById('def-coolbar');if(coolbar)coolbar.style.width='100%';
  RS.defTimer=setInterval(()=>{
    RS.defendCooldown=Math.max(0,RS.defendCooldown-100);
    const pct=(RS.defendCooldown/RS.defCoolMax)*100;
    if(coolbar)coolbar.style.width=pct+'%';
    if(RS.defendCooldown<=0){clearInterval(RS.defTimer);defBtn.classList.remove('cooling');if(coolbar)coolbar.style.width='0%';}
  },100);
}

