.ri-req{position:absolute;bottom:0;left:0;right:0;background:rgba(232,0,45,.1);border-top:1px solid rgba(232,0,45,.18);padding:2px 8px;font-size:7.5px;font-family:'Orbitron',monospace;color:var(--red);}
.lb-table{width:100%;border-collapse:collapse;}
.lb-table th{font-family:'Orbitron',monospace;font-size:8px;color:var(--dim);padding:5px 4px;text-align:left;border-bottom:1px solid var(--border);letter-spacing:.5px;}
.lb-table td{padding:7px 4px;font-size:11px;border-bottom:1px solid rgba(255,255,255,.04);}
.lb-table tr.me td{color:var(--green);font-weight:700;}
.lb-p{font-family:'Orbitron',monospace;font-size:12px;font-weight:700;min-width:24px;}
.lb-p.p1{color:var(--gold);}.lb-p.p2{color:var(--silver);}.lb-p.p3{color:var(--bronze);}
