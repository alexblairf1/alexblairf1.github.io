#main::-webkit-scrollbar-thumb{background:var(--border);}
.screen{display:none;padding:14px 12px 72px;animation:fadeIn .2s ease;}
.screen.active{display:block;}
@keyframes fadeIn{from{opacity:0;transform:translateY(6px)}to{opacity:1;transform:none}}
#bnav{height:58px;background:var(--bg2);border-top:1px solid var(--border);display:flex;flex-shrink:0;}
.nb{flex:1;display:flex;flex-direction:column;align-items:center;justify-content:center;gap:1px;background:none;border:none;color:var(--dim);cursor:pointer;font-family:'Rajdhani',sans-serif;font-size:8px;font-weight:700;letter-spacing:.5px;text-transform:uppercase;transition:color .15s;position:relative;}
.nb .ni{font-size:17px;line-height:1;}
.nb.on{color:var(--red);}
.nb.on .ni{filter:drop-shadow(0 0 5px var(--red));}
.nb .notif{position:absolute;top:5px;right:calc(50% - 12px);width:7px;height:7px;background:var(--red);border-radius:50%;border:1px solid var(--bg);}
.sh{font-family:'Orbitron',monospace;font-size:14px;font-weight:700;margin-bottom:12px;display:flex;align-items:center;gap:8px;}
.sh::before{content:'';width:3px;height:17px;background:var(--red);box-shadow:0 0 8px var(--red);border-radius:2px;flex-shrink:0;}
.sh-right{margin-left:auto;font-size:10px;color:var(--dim);font-family:'Rajdhani',sans-serif;font-weight:600;}
.tb{font-family:'Orbitron',monospace;font-size:7px;font-weight:700;letter-spacing:1px;padding:2px 6px;border-radius:3px;display:inline-block;}
.tb-br{background:#3d1a05;color:#f0c080;border:1px solid var(--bronze);}
.tb-si{background:#252535;color:#d0d0d0;border:1px solid #707070;}
.tb-go{background:#3d2e00;color:#f5e060;border:1px solid var(--gold);}
.tb-ep{background:#1e0045;color:#d0a0ff;border:1px solid var(--epic);}
.tb-sp{background:#3d0010;color:#ffc080;border:1px solid var(--sp);}
.tb-pl{background:#003d20;color:#80ffb0;border:1px solid var(--green);}
.tb-car{background:#003040;color:#80e0ff;border:1px solid var(--accent);}
.btn{display:inline-flex;align-items:center;justify-content:center;gap:6px;border:none;border-radius:8px;padding:9px 16px;font-family:'Orbitron',monospace;font-size:10px;font-weight:700;letter-spacing:.8px;cursor:pointer;transition:all .15s;text-transform:uppercase;white-space:nowrap;}
.btn-r{background:var(--red);color:#fff;box-shadow:0 3px 14px rgba(232,0,45,.4);}
.btn-r:active{transform:scale(.96);}
.btn-a{background:transparent;color:var(--accent);border:1px solid var(--accent);}
.btn-g{background:linear-gradient(135deg,#7a5500,#d4aa00);color:#fff;}
.btn-e{background:linear-gradient(135deg,#4a0080,#8b25f0);color:#fff;}
.btn-dim{background:var(--bg3);color:var(--mid);border:1px solid var(--border);}
.btn-green{background:var(--green);color:#000;}
.btn-warn{background:var(--warn);color:#000;}
.btn-full{width:100%;}
.btn-sm{padding:6px 12px;font-size:9px;}
.inp{width:100%;background:var(--bg2);border:1px solid var(--border);border-radius:8px;padding:10px 12px;color:var(--text);font-family:'Rajdhani',sans-serif;font-size:14px;font-weight:600;outline:none;transition:border .2s;}
.inp:focus{border-color:var(--accent);}
.panel{background:var(--bg3);border:1px solid var(--border);border-radius:12px;padding:13px;margin-bottom:9px;}
.prog-wrap{background:rgba(255,255,255,.06);border-radius:4px;height:6px;overflow:hidden;margin:6px 0;}
.prog-fill{height:100%;border-radius:4px;transition:width .4s ease;}
.prog-br{background:linear-gradient(90deg,#8b4a10,var(--bronze));}
.prog-si{background:linear-gradient(90deg,#555,var(--silver));}
.prog-go{background:linear-gradient(90deg,#9b7000,var(--gold));}
.prog-ep{background:linear-gradient(90deg,#5a0090,var(--epic));}
.prog-green{background:linear-gradient(90deg,#007040,var(--green));}
.prog-red{background:linear-gradient(90deg,var(--red2),var(--red));}
.dc{border-radius:11px;position:relative;overflow:hidden;cursor:pointer;transition:transform .15s;border:1px solid;flex-shrink:0;}
.dc:active{transform:scale(.96);}
.dc-sm{width:128px;height:182px;}
.dc-lg{width:100%;max-width:170px;aspect-ratio:.68;border-radius:13px;}
.dc.br{background:linear-gradient(155deg,#110700,#1e0e02,#110700);border-color:#8b5010;box-shadow:0 3px 12px rgba(139,80,16,.22);}
.dc.si{background:linear-gradient(155deg,#0a0a12,#141420,#0a0a12);border-color:#505060;}
.dc.go{background:linear-gradient(155deg,#120e00,#1f1700,#120e00);border-color:#9b7a00;box-shadow:0 4px 18px rgba(155,122,0,.32);}
.dc.ep{background:linear-gradient(155deg,#080018,#130030,#080018);border-color:#6a18d0;box-shadow:0 4px 22px rgba(106,24,208,.45);}
.dc.sp{background:linear-gradient(155deg,#100004,#1c0008,#100004);border-color:#cc5000;box-shadow:0 4px 22px rgba(204,80,0,.4);}
.dc.pl{background:linear-gradient(155deg,#001208,#002015,#001208);border-color:#00804a;box-shadow:0 4px 20px rgba(0,128,74,.35);}
.dc.car{background:linear-gradient(155deg,#00101a,#001a28,#00101a);border-color:#006080;}
.dc-stripe{position:absolute;top:0;left:0;right:0;height:3px;border-radius:11px 11px 0 0;}
.dc-inner{padding:7px;height:100%;display:flex;flex-direction:column;}
.dc-badge{position:absolute;top:6px;left:6px;}
.dc-era{position:absolute;top:6px;right:6px;font-family:'Orbitron',monospace;font-size:6px;color:rgba(255,255,255,.3);letter-spacing:.5px;}
.dc-emo{font-size:42px;text-align:center;margin:10px 0 2px;line-height:1;}
.dc-sm .dc-emo{font-size:36px;margin:8px 0 2px;}
.dc-name{font-family:'Orbitron',monospace;font-size:7.5px;font-weight:700;text-align:center;text-transform:uppercase;line-height:1.25;}
.dc-team{font-size:7.5px;text-align:center;color:var(--dim);margin:2px 0;}
.dc-ovr{font-family:'Orbitron',monospace;font-size:22px;font-weight:900;text-align:center;line-height:1;margin:3px 0;}
.dc.br .dc-ovr{color:var(--bronze);}.dc.si .dc-ovr{color:var(--silver);}.dc.go .dc-ovr{color:var(--gold);}.dc.ep .dc-ovr{color:var(--epic2);}.dc.sp .dc-ovr{color:#ff9040;}.dc.pl .dc-ovr{color:var(--green);}.dc.car .dc-ovr{color:var(--accent);}
.dc-num-bg{font-family:'Orbitron',monospace;font-size:36px;font-weight:900;opacity:.1;position:absolute;right:3px;bottom:28px;line-height:1;}
.dc.br .dc-num-bg{color:var(--bronze);}.dc.si .dc-num-bg{color:var(--silver);}.dc.go .dc-num-bg{color:var(--gold);}.dc.ep .dc-num-bg{color:var(--epic);opacity:.18;}.dc.sp .dc-num-bg{color:var(--sp);opacity:.14;}.dc.pl .dc-num-bg{color:var(--green);}
.dc-stats{display:grid;grid-template-columns:1fr 1fr;gap:2px;margin-top:auto;padding-top:4px;border-top:1px solid rgba(255,255,255,.07);}
.dc-stats.three{grid-template-columns:repeat(3,1fr);}
.dc-sv{font-family:'Orbitron',monospace;font-size:11px;font-weight:700;text-align:center;line-height:1;}
.dc.br .dc-sv{color:var(--bronze);}.dc.si .dc-sv{color:var(--silver);}.dc.go .dc-sv{color:var(--gold);}.dc.ep .dc-sv{color:var(--epic2);}.dc.sp .dc-sv{color:#ff9040;}.dc.pl .dc-sv{color:var(--green);}.dc.car .dc-sv{color:var(--accent);}
.dc-sl{font-size:6px;text-align:center;color:var(--dim);text-transform:uppercase;}
.dc-sp-label{position:absolute;bottom:5px;left:0;right:0;text-align:center;font-size:6px;font-family:'Orbitron',monospace;color:#ff9040;letter-spacing:.5px;padding:0 3px;}
.hscroll{display:flex;gap:10px;overflow-x:auto;padding-bottom:6px;scrollbar-width:none;}
.hscroll::-webkit-scrollbar{display:none;}
.cgrid{display:grid;grid-template-columns:repeat(2,1fr);gap:11px;justify-items:center;}
.fpills{display:flex;gap:7px;overflow-x:auto;scrollbar-width:none;padding-bottom:4px;margin-bottom:12px;}
.fpills::-webkit-scrollbar{display:none;}
.fp{flex-shrink:0;background:var(--bg3);border:1px solid var(--border);border-radius:14px;padding:5px 12px;font-family:'Rajdhani',sans-serif;font-size:11px;font-weight:700;color:var(--dim);cursor:pointer;transition:all .15s;}
.fp.on,.fp:hover{background:var(--red);border-color:var(--red);color:#fff;}
.hero{background:radial-gradient(ellipse at 30% 0%,#1a0008 0%,#0a0010 45%,var(--bg) 100%);border:1px solid #3a0015;border-radius:15px;padding:20px 16px;margin-bottom:14px;position:relative;overflow:hidden;}
.hero::after{content:'🏎';font-size:80px;position:absolute;right:-8px;bottom:-12px;opacity:.08;transform:scaleX(-1);}
.hero h1{font-family:'Orbitron',monospace;font-size:20px;font-weight:900;line-height:1.1;}
.hero h1 em{color:var(--red);font-style:normal;text-shadow:0 0 18px rgba(232,0,45,.8);}
.hero p{font-size:12px;color:var(--mid);margin:7px 0 13px;line-height:1.5;}
.league-card{background:var(--bg3);border:1px solid var(--border2);border-radius:13px;padding:14px;margin-bottom:14px;}
.lc-top{display:flex;align-items:center;gap:10px;margin-bottom:8px;}
.lc-icon{font-size:30px;}
.lc-title{font-family:'Orbitron',monospace;font-size:14px;font-weight:700;}
.lc-xp{font-size:11px;color:var(--dim);margin-top:2px;}
.lc-pct{font-family:'Orbitron',monospace;font-size:13px;font-weight:700;margin-left:auto;}
.quickgrid{display:grid;grid-template-columns:1fr 1fr;gap:9px;margin-bottom:16px;}
.qc{background:var(--bg3);border:1px solid var(--border);border-radius:11px;padding:12px;cursor:pointer;transition:border-color .15s;display:flex;flex-direction:column;gap:5px;}
.qc:hover{border-color:var(--red);}
.qc .qi{font-size:22px;}
.qc .qt{font-family:'Orbitron',monospace;font-size:10px;font-weight:700;}
.qc .qs{font-size:10px;color:var(--dim);}
.pack-section-title{font-family:'Orbitron',monospace;font-size:10px;font-weight:700;color:var(--mid);letter-spacing:2px;text-transform:uppercase;margin:14px 0 8px;padding-left:4px;}
