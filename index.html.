function advLap(){
  if(!RS.running||RS.dnf)return;
  // Decision check
  if(RS.nextDecIdx<RS.decLaps.length&&RS.lap>=RS.decLaps[RS.nextDecIdx]){
    const dec=RS.decisions[RS.nextDecIdx++];
    showDecision(dec);return;
  }
  const ev=LAP_EVENTS[Math.floor(Math.random()*LAP_EVENTS.length)]();
  addRaceLog(ev.msg,ev.cls);
  // Drift gap naturally (AI fights back)
  if(ev.gapChange)RS.aheadGap=Math.max(0.1,Math.min(15,RS.aheadGap+(ev.gapChange||0)));
  RS.behindGap=Math.max(0.1,Math.min(20,RS.behindGap+(Math.random()-.45)*0.8));
  // Passive position drift (hard to move without player action)
  if(Math.random()<.1&&RS.playerPos>1)RS.aheadGap=Math.max(0.1,RS.aheadGap-0.3);
  if(Math.random()<.08&&RS.playerPos<14){RS.behindGap=Math.max(0.1,RS.behindGap-0.5);if(RS.behindGap<0.2){RS.playerPos++;addRaceLog('OVERTAKEN — lost a position!','dan');RS.behindGap=1.5+Math.random();}}
  RS.lap++;
  if(RS.lap>RS.totalLaps){RS.running=false;const fp=RS.playerPos;addRaceLog(fp===1?'🏆 VICTORY — CHEQUERED FLAG!':'P'+fp+' — RACE COMPLETE!',fp<=3?'ok':'');}
  updateRaceUI();updateCarPositions();
}

