function pickColor(c,el){document.querySelectorAll('.csw').forEach(s=>s.classList.remove('on'));el.classList.add('on');G.team.color=c;}
function checkTeamGoal(){if(G.team.d1&&G.team.d2&&G.team.car)completeGoal('g3');}

// ════ SEASON ════
function renderSeason(){
  const tabs=document.getElementById('season-tabs');tabs.innerHTML='';
  Object.entries(LEAGUES).forEach(([id,lg])=>{
    const unlocked=isLeagueUnlocked(id);
    const btn=document.createElement('button');btn.className=`stab ${id} ${ACTIVE_LEAGUE===id?'on':''} ${!unlocked?'locked':''}`;btn.textContent=lg.emoji+' '+lg.name;
