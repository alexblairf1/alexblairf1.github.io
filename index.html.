      <div class="rp-gap ${gapCls}">${e.isMe?'':e.gapStr}</div>
    </div>`;
  }).join('');
  // Buttons
  if(RS.dnf||!RS.running){
    document.getElementById('btn-next-lap').style.opacity='.4';
    document.getElementById('btn-overtake').style.opacity='.3';
    document.getElementById('btn-defend').style.opacity='.3';
