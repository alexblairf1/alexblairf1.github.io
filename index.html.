  const lbData=[...sp.lb];lbData.sort((a,b)=>b.pts-a.pts);const top=lbData.slice(0,5);const meI=lbData.findIndex(e=>e.isMe);if(meI>=5)top.push(lbData[meI]);
  document.getElementById('season-lb').innerHTML=`<div class="sh">CHAMPIONSHIP STANDINGS</div><div class="panel"><table class="lb-table"><tr><th>POS</th><th>DRIVER</th><th>WINS</th><th>PTS</th></tr>${top.map((e,i)=>{const pos=lbData.indexOf(e)+1;const c=pos===1?'p1':pos===2?'p2':pos===3?'p3':'';return`<tr class="${e.isMe?'me':''}"><td class="lb-p ${c}">${pos}</td><td>${e.isMe?'⭐ YOU':e.name}</td><td>${e.wins}</td><td>${numFmt(e.pts)}</td></tr>`}).join('')}</table></div>`;
  document.getElementById('race-progress-lbl').textContent=`${sp.progress}/${lg.races.length}`;
  const rl=document.getElementById('race-list');rl.innerHTML='';
  lg.races.forEach((r,i)=>{
    const done=i<sp.progress;const isNext=i===sp.progress;const locked=i>sp.progress;
    const coins=Math.round((lg.baseRewards[i]||lg.baseRewards[lg.baseRewards.length-1])*lg.rewardMult);
    const div=document.createElement('div');div.className=`race-item ${done?'ri-done':''} ${isNext?'ri-next':''} ${locked?'ri-lk':''}`;
    div.innerHTML=`<div class="ri-flag">${r.flag}</div><div class="ri-info"><div class="ri-name">${r.name} Grand Prix</div><div class="ri-sub">${r.circuit} · ${r.laps} laps</div></div><div class="ri-rew"><div class="ri-coins">🪙${numFmt(coins)}</div><div class="ri-pts">+${lg.races.length>8?25:12} pts</div></div>${done?'<div class="ri-badge done">✓</div>':''}${isNext?'<div class="ri-badge next">▶ GO</div>':''}${lg.minOvr>0?`<div class="ri-req">Min OVR ${lg.minOvr} required</div>`:''}`;
    if(isNext)div.onclick=()=>startRace(r,i,ACTIVE_LEAGUE);
