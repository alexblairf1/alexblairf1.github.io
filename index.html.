.pick-title{font-family:'Orbitron',monospace;font-size:14px;font-weight:700;color:var(--text);text-align:center;}
.pick-sub{font-size:12px;color:var(--mid);text-align:center;}
.pick-grid{display:flex;gap:12px;justify-content:center;flex-wrap:wrap;}
.team-stats-row{display:grid;grid-template-columns:repeat(4,1fr);gap:8px;margin-bottom:13px;}
.ts-box{background:var(--bg3);border:1px solid var(--border);border-radius:10px;padding:9px;text-align:center;}
.ts-v{font-family:'Orbitron',monospace;font-size:17px;font-weight:700;}
.ts-l{font-size:8px;color:var(--dim);text-transform:uppercase;letter-spacing:.4px;margin-top:2px;}
.tslot{background:var(--bg3);border:1px dashed var(--border);border-radius:11px;padding:11px;display:flex;align-items:center;gap:10px;cursor:pointer;transition:all .15s;margin-bottom:9px;}
.tslot:hover{border-color:var(--accent);}
.tslot.filled{border-style:solid;}
.tslot-lbl{font-size:9px;font-family:'Orbitron',monospace;color:var(--dim);text-transform:uppercase;letter-spacing:.8px;margin-bottom:6px;}
.tslot-emo{font-size:26px;flex-shrink:0;}
.tslot-info{flex:1;}
.tslot-name{font-family:'Orbitron',monospace;font-size:11px;font-weight:700;}
.tslot-sub{font-size:9px;color:var(--dim);margin-top:2px;}
.color-row{display:flex;align-items:center;gap:7px;margin:8px 0;}
.csw{width:22px;height:22px;border-radius:50%;cursor:pointer;border:2px solid transparent;transition:all .15s;flex-shrink:0;}
.csw.on{border-color:#fff;box-shadow:0 0 6px rgba(255,255,255,.5);transform:scale(1.2);}
.upg-card{background:var(--bg3);border:1px solid var(--border);border-radius:12px;padding:12px;display:flex;align-items:center;gap:11px;margin-bottom:9px;cursor:pointer;transition:border-color .15s;}
.upg-card:hover{border-color:var(--gold);}
.upg-emo{font-size:30px;flex-shrink:0;}
.upg-info{flex:1;}
.upg-name{font-family:'Orbitron',monospace;font-size:11px;font-weight:700;}
.upg-sub{font-size:10px;color:var(--dim);margin-top:2px;}
.upg-cost{font-family:'Orbitron',monospace;font-size:11px;color:var(--gold);flex-shrink:0;}
.season-tabs{display:flex;gap:7px;margin-bottom:12px;overflow-x:auto;scrollbar-width:none;}
.season-tabs::-webkit-scrollbar{display:none;}
.stab{flex-shrink:0;background:var(--bg3);border:1px solid var(--border);border-radius:20px;padding:6px 14px;font-family:'Orbitron',monospace;font-size:9px;font-weight:700;cursor:pointer;transition:all .15s;color:var(--dim);letter-spacing:.8px;}
.stab.on{color:#fff;}
.stab.br.on{background:#5a2000;border-color:var(--bronze);color:#ffc060;}
.stab.si.on{background:#303040;border-color:var(--silver);color:#e0e0e0;}
.stab.go.on{background:#3d2e00;border-color:var(--gold);color:#ffe060;}
.stab.ep.on{background:#280050;border-color:var(--epic);color:#d0a0ff;}
.stab.locked{opacity:.3;cursor:not-allowed;}
.season-hbox{background:var(--bg3);border:1px solid var(--border2);border-radius:13px;padding:13px;margin-bottom:12px;}
.shb-top{display:flex;align-items:center;gap:10px;margin-bottom:8px;}
.shb-icon{font-size:26px;}
.shb-title{font-family:'Orbitron',monospace;font-size:14px;font-weight:700;}
.shb-stats{display:flex;gap:10px;font-family:'Orbitron',monospace;font-size:9px;color:var(--mid);margin-top:3px;}
.shb-chip{background:rgba(255,255,255,.05);border:1px solid var(--border);border-radius:8px;padding:3px 8px;font-size:9px;font-family:'Orbitron',monospace;}
