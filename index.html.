.ri-flag{font-size:23px;flex-shrink:0;}
.ri-info{flex:1;}
.ri-name{font-family:'Orbitron',monospace;font-size:10px;font-weight:700;}
.ri-sub{font-size:9px;color:var(--dim);margin-top:2px;}
.ri-rew{text-align:right;flex-shrink:0;}
.ri-coins{font-family:'Orbitron',monospace;font-size:10px;color:var(--gold);}
.ri-pts{font-size:9px;color:var(--dim);}
.ri-badge{position:absolute;top:7px;right:8px;font-size:9px;font-family:'Orbitron',monospace;}
.ri-badge.done{color:var(--green);}
.ri-badge.next{color:var(--gold);animation:blink 1.4s infinite;}
