function doBuyPack(pack){
  if(pack.isFree){
    if(G.starterUsed){toast('❌ Already used starter pack');return;}
    G.starterUsed=true;
  } else {
    if(pack.costType==='coins'){
      if(G.coins<pack.cost){toast('❌ Not enough coins! Race to earn more.');return;}
      G.coins-=pack.cost;
    } else {
      if(G.gems<pack.cost){toast('❌ Not enough gems!');return;}
      G.gems-=pack.cost;
    }
  }
  updateHUD();
  // generate cards
  const cards=[];
  for(let i=0;i<pack.count;i++){
    const roll=Math.random()*100;
    let cum=0,tier='br';
    for(const[t,w] of Object.entries(pack.tiers)){cum+=w;if(roll<cum){tier=t;break;}}
    let pool;
    if(pack.carsOnly) pool=ALL_CARS.filter(c=>c.tier===tier);
    else if(pack.canCar&&Math.random()<(pack.carChance||0)) pool=ALL_CARS.filter(c=>c.tier===tier);
    else pool=ALL_DRIVERS.filter(d=>d.tier===tier);
    if(!pool||!pool.length) pool=ALL_DRIVERS.filter(d=>d.tier==='br');
    // no dupes — remove already owned
    const notOwned=pool.filter(c=>!G.col.find(x=>x.id===c.id));
    cards.push(notOwned.length?notOwned[Math.floor(Math.random()*notOwned.length)]:pool[Math.floor(Math.random()*pool.length)]);
  }
  startPackReveal(cards);
}

function startPackReveal(cards){
  PK.cards=cards; PK.idx=0;
  document.getElementById('pack-open-over').classList.add('show');
  packRevealNext();
}
function packRevealNext(){
  if(PK.idx>=PK.cards.length) return;
  const card=PK.cards[PK.idx++];
  const isDupe=!!G.col.find(c=>c.id===card.id);
  addCard(card);
  addXP(card.tier==='br'?5:card.tier==='si'?20:card.tier==='go'?60:card.tier==='ep'?180:300);

  const slot=document.getElementById('pack-card-slot');
  slot.innerHTML='';
  const el=makeSmallCard(card);
  el.style.transform='scale(1.3)';
  el.style.pointerEvents='none';
  el.classList.add('card-reveal');
  slot.appendChild(el);

  document.getElementById('pack-card-name').textContent=card.name+(isDupe?' (DUPLICATE — no extra copy added)':'');
  document.getElementById('pack-card-name').style.color=isDupe?'var(--dim)':tierColor(card.tier);
  document.getElementById('pack-card-sub').textContent=`${card.team}${card.era?' · '+card.era:''}`;

  document.getElementById('pack-next-btn').style.display=PK.idx>=PK.cards.length?'none':'flex';
  document.getElementById('pack-done-btn').style.display=PK.idx>=PK.cards.length?'flex':'none';
  updateHUD();
}
