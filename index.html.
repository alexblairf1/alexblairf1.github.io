}
*{margin:0;padding:0;box-sizing:border-box;-webkit-tap-highlight-color:transparent;}
html,body{height:100%;overflow:hidden;font-family:'Rajdhani',sans-serif;}
body{background:var(--bg);color:var(--text);display:flex;flex-direction:column;}
#topbar{height:52px;background:linear-gradient(90deg,var(--bg),var(--bg2),var(--bg));border-bottom:2px solid var(--red2);display:flex;align-items:center;padding:0 12px;gap:8px;flex-shrink:0;box-shadow:0 2px 30px rgba(232,0,45,.2);}
.logo{font-family:'Orbitron',monospace;font-weight:900;font-size:18px;color:var(--red);letter-spacing:3px;text-shadow:0 0 18px rgba(232,0,45,.8);margin-right:auto;}
.logo b{color:var(--accent);}
.hud-chip{display:flex;align-items:center;gap:3px;background:var(--bg3);border:1px solid var(--border);border-radius:14px;padding:3px 9px;font-family:'Orbitron',monospace;font-size:10px;}
.hud-chip.gold{color:var(--gold);}
.hud-chip.gem{color:var(--epic2);}
.league-pill{font-family:'Orbitron',monospace;font-size:8px;font-weight:700;padding:3px 8px;border-radius:10px;letter-spacing:1px;}
.lp-br{background:#3d1a05;color:#f0c080;border:1px solid var(--bronze);}
.lp-si{background:#2a2a35;color:#d0d0d0;border:1px solid var(--silver);}
.lp-go{background:#3d2e00;color:#f5e060;border:1px solid var(--gold);}
.lp-ep{background:#2a0055;color:#d5a0ff;border:1px solid var(--epic);}
#main{flex:1;overflow-y:auto;overflow-x:hidden;}
