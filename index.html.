.pk{background:var(--bg3);border:1px solid var(--border);border-radius:12px;padding:13px 10px;text-align:center;cursor:pointer;transition:all .2s;position:relative;overflow:hidden;}
.pk:active{transform:scale(.97);}
.pk-br{border-color:#7a3c08;}.pk-si{border-color:#484858;}.pk-go{border-color:#8b7000;box-shadow:0 0 12px rgba(139,112,0,.18);}.pk-ep{border-color:#6818d0;box-shadow:0 0 16px rgba(104,24,208,.2);}
.pk-locked{opacity:.35;cursor:not-allowed !important;}
.pk-ico{font-size:36px;display:block;margin-bottom:5px;}
.pk-nm{font-family:'Orbitron',monospace;font-size:10px;font-weight:700;margin-bottom:3px;}
.pk-br .pk-nm{color:var(--bronze);}.pk-si .pk-nm{color:var(--silver);}.pk-go .pk-nm{color:var(--gold);}.pk-ep .pk-nm{color:var(--epic2);}
.pk-desc{font-size:9px;color:var(--dim);line-height:1.5;margin-bottom:7px;}
.pk-pr{font-family:'Orbitron',monospace;font-size:10px;}
.pk-br .pk-pr{color:var(--bronze);}.pk-si .pk-pr{color:var(--silver);}.pk-go .pk-pr{color:var(--gold);}.pk-ep .pk-pr{color:var(--epic2);}
.pk-lock-txt{font-size:8px;color:var(--red);font-family:'Orbitron',monospace;margin-top:4px;}
.pk-free-badge{position:absolute;top:7px;right:7px;background:var(--green);color:#000;font-family:'Orbitron',monospace;font-size:7px;padding:2px 6px;border-radius:8px;font-weight:700;}
#pack-ov{display:none;position:fixed;inset:0;background:rgba(0,0,0,.97);z-index:800;flex-direction:column;align-items:center;justify-content:center;gap:16px;}
#pack-ov.on{display:flex;}
.po-title{font-family:'Orbitron',monospace;font-size:18px;font-weight:900;color:var(--red);text-shadow:0 0 20px rgba(232,0,45,.8);}
.po-reveal-anim{animation:poReveal .5s cubic-bezier(.34,1.56,.64,1) both;}
@keyframes poReveal{from{transform:scale(.3) rotateY(180deg);opacity:0;}to{transform:scale(1.2);opacity:1;}}
#pick-ov{display:none;position:fixed;inset:0;background:rgba(0,0,0,.96);z-index:800;flex-direction:column;align-items:center;justify-content:center;gap:14px;padding:16px;}
