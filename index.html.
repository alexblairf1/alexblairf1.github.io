    if(isNext&&canRace) card.onclick=()=>startRace(race,lg,i);
    else if(isNext&&!canRace) card.onclick=()=>toast(`❌ Team OVR ${teamOvr} too low — need ${lg.minOvr}`);
    list.appendChild(card);
  });
}

