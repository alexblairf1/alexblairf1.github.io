function showDecision(dec){
  document.getElementById('dec-title').textContent='⚠️ '+dec.title;
  document.getElementById('dec-sit').textContent=dec.situation;
  const opts=document.getElementById('dec-opts');opts.innerHTML='';
  dec.options.forEach(opt=>{
    const div=document.createElement('div');div.className='dec-opt';
    div.innerHTML=`<div class="dec-opt-label">${opt.label}<span class="dec-risk risk-${opt.risk}">${opt.risk.toUpperCase()} RISK</span></div><div class="dec-opt-desc">${opt.desc}</div>`;
    div.onclick=()=>{document.getElementById('dec-ov').classList.remove('on');resolveDecision(opt);};
    opts.appendChild(div);
  });
  document.getElementById('dec-ov').classList.add('on');
}

function resolveDecision(opt){
  const eff=opt.eff;const failed=eff.fail&&Math.random()<eff.fail;
  if(failed){
    const fp=eff.failPos||2;RS.playerPos=Math.min(14,RS.playerPos+fp);
    RS.aheadGap=Math.min(15,RS.aheadGap+fp*1.5);
    if(eff.dnf){RS.running=false;RS.dnf=true;addRaceLog('💥 DNF — MECHANICAL FAILURE!','dan');}
    else addRaceLog('❌ '+opt.label+' failed! Lost '+fp+' places','dan');
  } else {
    const pg=eff.pos||0;
    if(pg<0){RS.playerPos=Math.max(1,RS.playerPos+pg);RS.aheadGap=Math.max(0.5,RS.aheadGap+(pg*1.2));}
    else if(pg>0){RS.playerPos=Math.min(14,RS.playerPos+pg);RS.aheadGap=Math.min(15,RS.aheadGap+(pg*2));}
    addRaceLog('✅ '+opt.label+' — '+( pg<0?'Gained '+(Math.abs(pg))+' places!':pg>0?'Lost '+pg+' places.':'Held position!'),'ok');
  }
  RS.lap++;if(RS.lap>RS.totalLaps)RS.running=false;
  updateRaceUI();updateCarPositions();
}

