  container.innerHTML='';
  if(!G.starterOpened){
    const s=document.createElement('div');
    s.innerHTML=`<div class="pk pk-br" onclick="openStarter()" style="border-color:var(--green);box-shadow:0 0 14px rgba(0,217,106,.18);grid-column:span 2;text-align:center;margin-bottom:12px"><div class="pk-free-badge">FREE</div><span class="pk-ico">🎁</span><div class="pk-nm" style="color:var(--green)">STARTER PACK</div><div class="pk-desc">3 Bronze driver cards. Claim once.</div><div class="pk-pr" style="color:var(--green)">FREE — CLAIM NOW</div></div>`;
    container.appendChild(s);
  }
  const dTitle=document.createElement('div');dTitle.className='pack-section-title';dTitle.textContent='DRIVER PACKS';container.appendChild(dTitle);
  const dGrid=document.createElement('div');dGrid.className='pack-grid';container.appendChild(dGrid);
  PACKS.filter(p=>p.cat==='driver'&&!p.isFree).forEach(p=>{
    const locked=isPackLocked(p);
    const div=document.createElement('div');
    div.className=`pk pk-${p.type} ${locked?'pk-locked':''}`;
    div.innerHTML=`<span class="pk-ico">${p.ico}</span><div class="pk-nm">${p.name}</div><div class="pk-desc">${p.desc}</div><div class="pk-pr">${p.cost?'🪙 '+numFmt(p.cost):'💎 '+p.gem}</div>${locked?`<div class="pk-lock-txt">🔒 ${p.needLeague.toUpperCase()} LEAGUE REQUIRED</div>`:''}`;
    if(!locked)div.onclick=()=>buyPack(p);
    dGrid.appendChild(div);
  });
  const cTitle=document.createElement('div');cTitle.className='pack-section-title';cTitle.textContent='CAR PACKS';container.appendChild(cTitle);
  const cGrid=document.createElement('div');cGrid.className='pack-grid';container.appendChild(cGrid);
  PACKS.filter(p=>p.cat==='car').forEach(p=>{
    const locked=isPackLocked(p);
    const achLocked=p.achieveReq&&!p.achieveCheck?.();
    const div=document.createElement('div');
    div.className=`pk pk-${p.type} ${(locked||achLocked)?'pk-locked':''}`;
    div.innerHTML=`<span class="pk-ico">${p.ico}</span><div class="pk-nm">${p.name}</div><div class="pk-desc">${p.desc}</div><div class="pk-pr">${p.cost?'🪙 '+numFmt(p.cost):'💎 '+p.gem}</div>${locked?`<div class="pk-lock-txt">🔒 ${p.needLeague.toUpperCase()} LEAGUE REQUIRED</div>`:''}${achLocked&&!locked?`<div class="pk-lock-txt">🔒 ${p.achieveReq}</div>`:''}`;
    if(!locked&&!achLocked)div.onclick=()=>buyPack(p);
    cGrid.appendChild(div);
  });
}

function isPackLocked(p){
  const order=['br','si','go','ep'];
  return order.indexOf(G.careerLeague)<order.indexOf(p.needLeague)||G.level<p.needLevel;
}
function openStarter(){G.starterOpened=true;const pool=DRIVERS_RAW.filter(d=>d.tier==='br');const cards=[pool[Math.floor(Math.random()*pool.length)],pool[Math.floor(Math.random()*pool.length)],pool[Math.floor(Math.random()*pool.length)]];startPackReveal(cards);completeGoal('g1');}
function buyPack(p){if(p.cost&&G.coins<p.cost){toast('❌ Not enough coins! Race to earn more.');return;}if(p.gem&&G.gems<p.gem){toast('❌ Not enough gems!');return;}if(p.cost)G.coins-=p.cost;if(p.gem)G.gems-=p.gem;updateHUD();startPackReveal(generatePack(p));completeGoal('g1');}
function generatePack(p){const cards=[];for(let i=0;i<p.count;i++){const r=Math.random()*100;let cum=0,tier='br';for(const[t,w] of Object.entries(p.weights)){cum+=w;if(r<cum){tier=t;break;}}const pool=p.cat==='car'?CARS_RAW.filter(c=>c.tier===tier):DRIVERS_RAW.filter(d=>d.tier===tier);if(!pool.length){cards.push(DRIVERS_RAW[0]);continue;}cards.push(pool[Math.floor(Math.random()*pool.length)]);}return cards;}

function startPackReveal(cards){PK={cards,idx:0};document.getElementById('pack-ov').classList.add('on');revealNext();}
function revealNext(){
  if(PK.idx>=PK.cards.length)return;
  const card=PK.cards[PK.idx++];
  addToCollection(card);
  const wrap=document.getElementById('po-card-wrap');wrap.innerHTML='';
  const el=makeSmCard(card);el.style.transform='scale(1.22)';el.style.pointerEvents='none';el.classList.add('po-reveal-anim');wrap.appendChild(el);
  const tc=TIER[card.tier]?.color||'#888';
  document.getElementById('po-info').innerHTML=`<div style="color:${tc};font-size:14px;font-weight:700">${card.name}</div><div style="color:var(--mid);font-size:11px;margin-top:3px">${card.team}${card.era?' · '+card.era:''}</div><div style="margin-top:6px"><span class="tb ${TIER[card.tier]?.badge||'tb-br'}">${TIER[card.tier]?.label||'BRONZE'}</span></div>`;
  document.getElementById('po-count').textContent=`Card ${PK.idx} of ${PK.cards.length}`;
  document.getElementById('po-next-btn').style.display=PK.idx>=PK.cards.length?'none':'flex';
  document.getElementById('po-done-btn').style.display=PK.idx>=PK.cards.length?'flex':'none';
  updateHUD();
}
function packDone(){document.getElementById('pack-ov').classList.remove('on');renderCollection();renderTeam();renderHome();toast('✅ Cards added to collection!');}
function addToCollection(card){
  const isCar=!!card.speed;const pool=isCar?G.cars:G.col;
  const ex=pool.find(c=>c.id===card.id);
  if(ex){G.dupes[card.id]=(G.dupes[card.id]||0)+1;toast('📋 Duplicate! '+( card.short||card.name)+' → upgrade material');}
  else{pool.push({...card,uid:Date.now()+Math.random()});addXP(card.tier==='br'?8:card.tier==='si'?20:card.tier==='go'?50:card.tier==='ep'?120:200);}
}

