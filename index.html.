// ════ TEAM ════
function renderTeam(){
  const d1=G.team.d1,d2=G.team.d2,car=G.team.car;
  const drivers=[d1,d2].filter(Boolean);
  const dOvr=drivers.length?Math.round(drivers.reduce((s,d)=>s+(d.overall+(G.upgrades[d.id]||0)*2),0)/drivers.length):0;
