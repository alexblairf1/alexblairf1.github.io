.upg-stat-row:last-child{border-bottom:none;}
.upg-stat-name{font-size:12px;color:var(--mid);}
.driver-card-profile{background:linear-gradient(155deg,var(--bg2),var(--bg3));border:1px solid var(--border2);border-radius:14px;padding:16px;margin-bottom:13px;display:flex;gap:14px;align-items:center;}
.dcp-emo{font-size:52px;flex-shrink:0;}
.dcp-info{flex:1;}
.dcp-name{font-family:'Orbitron',monospace;font-size:15px;font-weight:700;color:var(--green);}
.dcp-team{font-size:11px;color:var(--dim);margin:2px 0;}
.ev-card{background:var(--bg3);border:1px solid var(--border);border-radius:13px;padding:13px;margin-bottom:10px;cursor:pointer;transition:border-color .15s;position:relative;overflow:hidden;}
.ev-card:hover{border-color:var(--red);}
.ev-card.sp{border-color:#aa4000;box-shadow:0 0 12px rgba(170,64,0,.15);}
.ev-card.weekly{border-color:#5018a0;}
.ev-card.daily{border-color:#006878;}
.ev-hd{display:flex;align-items:center;gap:10px;margin-bottom:7px;}
.ev-icon{font-size:26px;flex-shrink:0;}
.ev-title{font-family:'Orbitron',monospace;font-size:11px;font-weight:700;line-height:1.3;}
.ev-type{font-size:9px;color:var(--dim);letter-spacing:.8px;text-transform:uppercase;margin-top:2px;}
.ev-desc{font-size:11px;color:var(--mid);line-height:1.5;margin-bottom:8px;}
.ev-chips{display:flex;gap:6px;flex-wrap:wrap;}
.ev-chip{font-size:9px;font-family:'Orbitron',monospace;padding:2px 8px;border-radius:10px;border:1px solid rgba(255,255,255,.1);background:rgba(255,255,255,.04);}
.ev-chip.gold{color:var(--gold);border-color:rgba(245,197,24,.25);}.ev-chip.ep{color:var(--epic2);border-color:rgba(139,37,240,.25);}.ev-chip.xp{color:var(--green);border-color:rgba(0,217,106,.25);}
.ev-lim{position:absolute;top:9px;right:9px;background:var(--red);color:#fff;font-size:7px;font-family:'Orbitron',monospace;padding:2px 7px;border-radius:8px;animation:blink 2s infinite;}
.ev-req{font-size:9px;color:var(--dim);margin-top:6px;font-family:'Orbitron',monospace;}
.ev-req.locked{color:var(--red);}
#toast{position:fixed;bottom:68px;left:50%;transform:translateX(-50%) translateY(8px);background:var(--bg3);border:1px solid var(--border);border-radius:18px;padding:8px 16px;font-family:'Orbitron',monospace;font-size:10px;z-index:900;opacity:0;transition:opacity .25s,transform .25s;white-space:nowrap;pointer-events:none;max-width:92vw;overflow:hidden;text-overflow:ellipsis;}
#toast.on{opacity:1;transform:translateX(-50%) translateY(0);}

/* ═══════════════ RACE OVERLAY ═══════════════ */
#race-ov{display:none;position:fixed;inset:0;background:var(--bg);z-index:700;overflow:hidden;}
#race-ov.on{display:flex;flex-direction:column;}
/* Track visualization */
#track-canvas-wrap{position:relative;flex-shrink:0;height:220px;background:linear-gradient(180deg,#080d1e 0%,#050810 100%);overflow:hidden;border-bottom:2px solid var(--border);}
#track-road{position:absolute;bottom:0;left:0;right:0;height:70px;background:linear-gradient(0deg,#1a1a20,#111118);border-top:2px solid rgba(255,255,255,.06);}
.track-line{position:absolute;bottom:30px;height:4px;width:40px;background:rgba(255,255,255,.3);border-radius:2px;animation:trackLine 1.2s linear infinite;}
@keyframes trackLine{from{right:-50px;}to{right:110%}}
.pit-wall{position:absolute;top:0;left:0;right:0;height:8px;background:repeating-linear-gradient(90deg,var(--red) 0px,var(--red) 8px,#fff 8px,#fff 16px);}
.race-car-main{position:absolute;bottom:36px;transition:left .3s cubic-bezier(.34,1.2,.64,1),filter .2s;font-size:32px;filter:drop-shadow(0 0 10px var(--red));}
.race-car-ai{position:absolute;bottom:36px;font-size:28px;transition:left .25s ease,bottom .2s ease;opacity:.9;}
.race-car-ai.ahead{bottom:56px;}

/* Race info panel */
#race-info-panel{flex-shrink:0;background:var(--bg2);border-bottom:1px solid var(--border);padding:8px 12px;display:grid;grid-template-columns:1fr 1fr 1fr;gap:6px;}
.rip-item{text-align:center;}
.rip-val{font-family:'Orbitron',monospace;font-size:14px;font-weight:700;}
.rip-lbl{font-size:8px;color:var(--dim);text-transform:uppercase;letter-spacing:.5px;margin-top:1px;}

/* Position list */
#race-pos-panel{flex:1;overflow-y:auto;padding:8px 12px;}
.rp-row{display:flex;align-items:center;gap:9px;padding:7px 10px;background:var(--bg3);border:1px solid var(--border);border-radius:9px;margin-bottom:6px;transition:all .2s;}
.rp-row.me{border-color:var(--accent);background:rgba(0,184,224,.04);}
.rp-row.ahead-row{border-color:rgba(255,170,0,.4);background:rgba(255,170,0,.03);}
.rp-n{font-family:'Orbitron',monospace;font-size:14px;font-weight:900;min-width:24px;}
.rp-row:nth-child(1) .rp-n{color:var(--gold);}.rp-row:nth-child(2) .rp-n{color:var(--silver);}.rp-row:nth-child(3) .rp-n{color:var(--bronze);}
.rp-name{flex:1;font-size:12px;font-weight:700;}
.rp-gap{font-family:'Share Tech Mono',monospace;font-size:10px;color:var(--dim);}
.rp-gap.close{color:var(--warn);}
.rp-gap.very-close{color:var(--red);font-weight:700;animation:blink .8s infinite;}

/* Race log */
#race-log-panel{flex-shrink:0;height:66px;overflow-y:auto;padding:6px 12px;background:var(--bg3);border-top:1px solid var(--border);}
.rle{font-family:'Share Tech Mono',monospace;font-size:9.5px;margin-bottom:2px;color:var(--dim);}
.rle.hi{color:var(--accent);}.rle.ok{color:var(--green);}.rle.dan{color:var(--red);}.rle.warn{color:var(--warn);}

/* Control buttons */
#race-controls{flex-shrink:0;padding:10px 12px;background:var(--bg2);border-top:1px solid var(--border);display:flex;gap:8px;}
.race-ctrl-btn{flex:1;padding:12px 6px;border:none;border-radius:10px;font-family:'Orbitron',monospace;font-size:10px;font-weight:700;cursor:pointer;transition:all .15s;letter-spacing:.5px;position:relative;overflow:hidden;}
.race-ctrl-btn:active{transform:scale(.95);}
#btn-overtake{background:linear-gradient(135deg,#c80020,#e8002d);color:#fff;box-shadow:0 4px 16px rgba(232,0,45,.5);border:1px solid rgba(255,100,100,.3);}
#btn-overtake.cooling{background:linear-gradient(135deg,#3a0010,#5a0018);color:rgba(255,255,255,.4);box-shadow:none;cursor:not-allowed;}
#btn-overtake .coolbar{position:absolute;bottom:0;left:0;height:3px;background:var(--red);border-radius:0 0 10px 10px;transition:width .1s linear;}
#btn-defend{background:linear-gradient(135deg,#005a78,#0090c0);color:#fff;box-shadow:0 4px 16px rgba(0,144,192,.4);border:1px solid rgba(100,200,255,.3);}
#btn-defend.cooling{background:linear-gradient(135deg,#001824,#003048);color:rgba(255,255,255,.4);box-shadow:none;cursor:not-allowed;}
#btn-defend .coolbar{position:absolute;bottom:0;left:0;height:3px;background:var(--accent);border-radius:0 0 10px 10px;transition:width .1s linear;}
#btn-pit{background:linear-gradient(135deg,#5a4500,#906e00);color:#fff;box-shadow:0 3px 12px rgba(144,110,0,.35);border:1px solid rgba(255,200,60,.3);}
#btn-pit.used{background:var(--bg3);color:var(--dim);box-shadow:none;cursor:not-allowed;border:1px solid var(--border);}
#btn-next-lap{background:var(--bg3);color:var(--mid);border:1px solid var(--border);}
#btn-quit-race{background:transparent;color:var(--dim);border:1px solid var(--border);flex:0 0 auto;padding:12px 14px;}
.race-ctrl-icon{font-size:18px;display:block;margin-bottom:2px;}
.race-ctrl-lbl{font-size:8px;letter-spacing:.8px;}
.overtake-flash{animation:overtakeFlash .4s ease;}
@keyframes overtakeFlash{0%{background:rgba(0,255,100,.15);}100%{background:transparent;}}
.fail-flash{animation:failFlash .4s ease;}
@keyframes failFlash{0%{background:rgba(255,0,45,.15);}100%{background:transparent;}}

/* Decision overlay */
#dec-ov{display:none;position:fixed;inset:0;background:rgba(0,0,0,.92);z-index:810;flex-direction:column;align-items:center;justify-content:flex-end;padding:14px;}
#dec-ov.on{display:flex;}
.dec-box{background:var(--bg2);border:1px solid var(--border2);border-radius:18px 18px 14px 14px;width:100%;max-width:480px;padding:18px;}
.dec-title{font-family:'Orbitron',monospace;font-size:13px;font-weight:700;color:var(--warn);margin-bottom:5px;display:flex;align-items:center;gap:8px;}
.dec-situation{font-size:11px;color:var(--mid);margin-bottom:13px;line-height:1.5;}
.dec-options{display:flex;flex-direction:column;gap:7px;}
.dec-opt{background:var(--bg3);border:1px solid var(--border);border-radius:10px;padding:11px 13px;cursor:pointer;transition:all .15s;}
.dec-opt:hover,.dec-opt:active{border-color:var(--accent);background:rgba(0,184,224,.04);}
.dec-opt-label{font-family:'Orbitron',monospace;font-size:10px;font-weight:700;margin-bottom:3px;display:flex;align-items:center;gap:7px;}
.dec-opt-desc{font-size:10px;color:var(--mid);}
.dec-risk{font-size:8px;font-family:'Orbitron',monospace;padding:2px 6px;border-radius:8px;margin-left:auto;}
.risk-low{background:rgba(0,217,106,.12);color:var(--green);border:1px solid rgba(0,217,106,.25);}
.risk-med{background:rgba(255,170,0,.12);color:var(--warn);border:1px solid rgba(255,170,0,.25);}
.risk-high{background:rgba(232,0,45,.12);color:var(--red);border:1px solid rgba(232,0,45,.25);}

/* Result overlay */
#result-ov{display:none;position:fixed;inset:0;background:rgba(0,0,0,.94);z-index:820;flex-direction:column;align-items:center;justify-content:center;gap:13px;padding:20px;}
#result-ov.on{display:flex;}
.result-box{background:var(--bg2);border:1px solid var(--border2);border-radius:18px;width:100%;max-width:400px;padding:20px;text-align:center;}
.result-pos{font-family:'Orbitron',monospace;font-size:52px;font-weight:900;line-height:1;}
.result-label{font-size:13px;color:var(--mid);margin:4px 0 13px;}
.rew-row{display:flex;align-items:center;justify-content:space-between;background:var(--bg3);border:1px solid var(--border);border-radius:9px;padding:8px 12px;margin-bottom:6px;}
.rew-lbl{font-size:11px;color:var(--mid);}
.rew-val{font-family:'Orbitron',monospace;font-size:12px;font-weight:700;}
</style>
</head>
