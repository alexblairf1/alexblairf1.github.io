  nameDiv.className='md-section';
  nameDiv.innerHTML=`<div class="md-title">DRIVER NAME</div>
    <input id="md-name-inp" style="width:100%;background:var(--bg);border:1px solid var(--border);border-radius:8px;padding:8px 12px;font-family:'Orbitron',monospace;font-size:13px;color:var(--text);outline:none;" value="${md.name}" maxlength="16">
    <button class="btn btn-cyan full" style="margin-top:8px" onclick="saveMDName()">SAVE NAME</button>`;
  c.appendChild(nameDiv);
}

function upgradeMyDriver(stat,cost){
  const md=G.myDriver;
  if(G.coins<cost){toast('❌ Not enough coins!');return;}
  if(md[stat]>=90){toast('❌ Already maxed!');return;}
  G.coins-=cost;
  md[stat]++;
  md.upgradeCosts[stat]=Math.round(cost*1.35); // gets more expensive
  md.overall=Math.round((md.pace+md.consistency+md.racecraft+md.overtaking)/4);
  toast(`✅ ${stat} upgraded to ${md[stat]}!`);
  // check team promotion
  const myTeam=MY_DRIVER_TEAMS.find(t=>t.id===md.team)||MY_DRIVER_TEAMS[0];
  const nextTeam=MY_DRIVER_TEAMS[MY_DRIVER_TEAMS.indexOf(myTeam)+1];
  if(nextTeam&&G.xp>=nextTeam.reqXP) toast(`🎉 You can now promote to ${nextTeam.name}!`);
  updateHUD();
  renderMyDriver();
  renderTeam();
}

function saveMDName(){
  G.myDriver.name=document.getElementById('md-name-inp').value||'MY DRIVER';
  toast('✅ Name saved!');renderMyDriver();renderTeam();
}

/* ──────────────────────────────────────────────
   CARD DETAIL MODAL
────────────────────────────────────────────── */
function openCardDetail(d){
  const isCar=!!d.isCar;
  const tc=tierColor(d.tier);

  const cardSlot=document.getElementById('card-modal-card');
  cardSlot.innerHTML='';
  const el=makeSmallCard(d);
  el.style.transform='scale(1.2)';el.style.pointerEvents='none';el.style.marginBottom='6px';
  cardSlot.appendChild(el);

  const stats=isCar?
    [['Speed',d.speed],['Handling',d.handling],['Reliability',d.reliability],['Aerodynamics',d.aero]]:
    [['Pace',d.pace],['Consistency',d.consistency],['Racecraft',d.racecraft],['Overtaking',d.overtaking]];

  document.getElementById('card-modal-info').innerHTML=`
    <div style="text-align:center;margin-bottom:14px">
      <div style="font-family:'Orbitron',monospace;font-size:16px;font-weight:700">${d.name}</div>
      <div style="color:var(--dim);font-size:11px;margin-top:2px">${d.team}${d.era?' · '+d.era:''}</div>
      ${d.specialLabel?`<div style="font-size:9px;color:${tc};margin-top:4px">${d.specialLabel}</div>`:''}
    </div>
    ${stats.map(([l,v])=>`
      <div class="cd-statbar-row">
        <div class="cd-statbar-label">${l}</div>
        <div class="cd-statbar-track"><div class="cd-statbar-fill" style="width:${v}%;background:${tc}"></div></div>
        <div class="cd-statbar-val" style="color:${tc}">${v}</div>
      </div>`).join('')}
    <div style="display:flex;gap:8px;margin-top:14px;justify-content:center">
      <button class="btn btn-red" onclick="assignCard('${d.id}')">ADD TO TEAM</button>
      <button class="btn btn-cyan" onclick="openUpgrade('${d.id}')">⬆ UPGRADE</button>
    </div>`;
  openMod('card-modal');
}

function assignCard(id){
  const card=G.col.find(c=>c.id===id);
  if(!card){closeMod('card-modal');return;}
  if(card.isCar){G.team.car=card;toast('🏎 Car assigned!');}
  else if(!G.team.d1){G.team.d1=card;toast('✅ Driver 1 set!');}
  else{G.team.d2=card;toast('✅ Driver 2 set!');}
  closeMod('card-modal');
  renderTeam();checkTeamObj();checkLeagueUnlocks();
}

/* ──────────────────────────────────────────────
   UPGRADE MODAL
────────────────────────────────────────────── */
function openUpgrade(cardId){
  const card=G.col.find(c=>c.id===cardId);
  if(!card){toast('Card not found');return;}
  const tc=tierColor(card.tier);

  // Find next tier version
  const bases={'br':'si','si':'go','go':'ep','ep':null,'sp':null};
  const nextTier=bases[card.tier];
  const nextVersion=nextTier&&(card.base)?
    (ALL_DRIVERS.find(d=>d.base===card.base&&d.tier===nextTier)||
     ALL_CARS.find(c=>c.base===card.base&&c.tier===nextTier)):null;

  // Upgrade costs (boost stats slightly for coins)
  const upgCosts={br:120,si:600,go:3000,ep:15000,sp:null};
  const cost=upgCosts[card.tier];
  const isCar=!!card.isCar;

  document.getElementById('upgrade-modal-title').innerHTML=`UPGRADE CARD <button class="modal-close" onclick="closeMod('upgrade-modal')">✕</button>`;
  document.getElementById('upgrade-modal-body').innerHTML=`
    <div style="display:flex;justify-content:center;margin-bottom:14px">
      <div style="text-align:center">
        <div style="font-family:'Orbitron',monospace;font-size:13px;color:${tc};font-weight:700">${card.name}</div>
        <div style="font-size:10px;color:var(--dim)">${card.team}</div>
        ${tierBadge(card.tier)}
      </div>
    </div>

    <div style="background:var(--bg3);border:1px solid var(--border2);border-radius:var(--r);padding:12px;margin-bottom:12px">
      <div style="font-family:'Orbitron',monospace;font-size:10px;color:var(--dim);margin-bottom:8px">STAT BOOST (🪙${cost?.toLocaleString()||'N/A'})</div>
      ${cost?`<div style="font-size:11px;color:var(--mid);margin-bottom:10px">Spend coins to boost this card's stats by +2 across the board. Does not change tier.</div>
      <button class="btn btn-gold full" onclick="doStatBoost('${card.id}',${cost})">⬆ BOOST STATS — 🪙${cost?.toLocaleString()}</button>`:'<div style="font-size:11px;color:var(--dim)">Special cards cannot be stat-boosted.</div>'}
    </div>

    ${nextVersion&&!G.col.find(c=>c.id===nextVersion.id)?`
    <div style="background:linear-gradient(135deg,var(--bg3),var(--bg4));border:1px solid ${tierColor(nextTier||'br')};border-radius:var(--r);padding:12px">
      <div style="font-family:'Orbitron',monospace;font-size:10px;color:${tierColor(nextTier||'br')};margin-bottom:6px">UNLOCK NEXT TIER</div>
      <div style="font-size:11px;color:var(--mid);margin-bottom:10px">${nextVersion.name} ${TIERS[nextTier]?.label||''} version is available. Get it via packs — or save up!</div>
      <button class="btn btn-cyan full" onclick="closeMod('upgrade-modal');goTo('packs')">VIEW PACKS</button>
    </div>`:`
    <div style="background:var(--bg3);border:1px solid var(--border);border-radius:var(--r);padding:12px;text-align:center">
      <div style="font-size:11px;color:var(--dim)">${card.tier==='ep'||card.tier==='sp'?'This is the highest tier for this card.':'Higher tier already in collection, or not available.'}</div>
    </div>`}`;
  openMod('upgrade-modal');
}

function doStatBoost(id,cost){
  const card=G.col.find(c=>c.id===id);
  if(!card){return;}
  if(G.coins<cost){toast('❌ Not enough coins!');return;}
  G.coins-=cost;
  // boost stats
  if(card.isCar){card.speed=Math.min(100,card.speed+2);card.handling=Math.min(100,card.handling+2);card.reliability=Math.min(100,card.reliability+1);card.aero=Math.min(100,card.aero+2);card.overall=Math.min(100,card.overall+2);}
  else{card.pace=Math.min(100,card.pace+2);card.consistency=Math.min(100,card.consistency+2);card.racecraft=Math.min(100,card.racecraft+2);card.overtaking=Math.min(100,card.overtaking+2);card.overall=Math.min(100,card.overall+2);}
  toast(`✅ ${card.name} boosted! OVR → ${card.overall}`);
  updateHUD();
  closeMod('upgrade-modal');
  renderCollection();renderTeam();checkLeagueUnlocks();
}

/* ──────────────────────────────────────────────
   OBJECTIVES
────────────────────────────────────────────── */
function completeObj(id){
  const o=G.objectives.find(x=>x.id===id);
  if(o&&!o.done){
    o.done=true;
    addXP(o.xpRew);
    addCoins(o.coinRew);
    updateHUD();
    toast(`🎯 Objective: "${o.text}" — +${o.xpRew}XP +🪙${o.coinRew}`);
    renderHome();
  }
}

/* ──────────────────────────────────────────────
   NAV
────────────────────────────────────────────── */
function goTo(name, btn){
  document.querySelectorAll('.screen').forEach(s=>s.classList.remove('active'));
  document.getElementById('scr-'+name).classList.add('active');
  document.querySelectorAll('.nb').forEach(b=>b.classList.remove('on'));
  const navMap={home:0,packs:1,team:2,collection:3,season:4};
  if(btn) btn.classList.add('on');
  else if(navMap[name]!==undefined) document.querySelectorAll('.nb')[navMap[name]].classList.add('on');
  // refresh on navigate
  if(name==='team') renderTeam();
  if(name==='collection') renderCollection();
  if(name==='packs') renderPacks();
  if(name==='season') renderSeason();
  if(name==='home') renderHome();
  if(name==='my-driver') renderMyDriver();
  if(name==='events') renderEvents();
  document.getElementById('main').scrollTop=0;
}

/* ──────────────────────────────────────────────
   MODALS
────────────────────────────────────────────── */
function openMod(id){document.getElementById(id).classList.add('show');}
function closeMod(id){document.getElementById(id).classList.remove('show');}
['card-modal','slot-modal','upgrade-modal'].forEach(id=>{
  document.getElementById(id).addEventListener('click',function(e){if(e.target===this)closeMod(id);});
});

/* ──────────────────────────────────────────────
   TOAST
────────────────────────────────────────────── */
let toastTimer;
function toast(msg){
  const el=document.getElementById('toast');
  el.textContent=msg;el.classList.add('show');
  clearTimeout(toastTimer);
  toastTimer=setTimeout(()=>el.classList.remove('show'),3000);
}

/* ──────────────────────────────────────────────
   BOOT
────────────────────────────────────────────── */
init();
</script>
</body>
</html>
